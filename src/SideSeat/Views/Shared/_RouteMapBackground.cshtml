@using System.Text.Json
@using Microsoft.EntityFrameworkCore
@{
    var bgDb = Context.RequestServices.GetService(typeof(SideSeat.Data.SideSeatDbContext)) as SideSeat.Data.SideSeatDbContext;
    var bgRoutesJson = "[]";
    if (bgDb is not null)
    {
        var rawRoutes = bgDb.Voznje
            .AsNoTracking()
            .Where(v => v.Status == SideSeat.Models.StatusVoznje.Planirana
                && v.SlobodnaMjesta > 0
                && v.PolazniGrad.Latitude != null && v.PolazniGrad.Longitude != null
                && v.OdredisniGrad.Latitude != null && v.OdredisniGrad.Longitude != null
                && v.PolazniGradId != v.OdredisniGradId)
            .OrderByDescending(v => v.Polazak)
            .Select(v => new
            {
                v.PolazniGradId,
                v.OdredisniGradId,
                StartName = v.PolazniGrad.Naziv,
                StartLat = v.PolazniGrad.Latitude,
                StartLng = v.PolazniGrad.Longitude,
                EndName = v.OdredisniGrad.Naziv,
                EndLat = v.OdredisniGrad.Latitude,
                EndLng = v.OdredisniGrad.Longitude
            })
            .Take(80)
            .ToList();

        var distinct = rawRoutes
            .GroupBy(r => r.PolazniGradId <= r.OdredisniGradId
                ? (Low: r.PolazniGradId, High: r.OdredisniGradId)
                : (Low: r.OdredisniGradId, High: r.PolazniGradId))
            .Select(g => g.First())
            .Take(7)
            .Select(r => new
            {
                startName = r.StartName,
                startLat = r.StartLat,
                startLng = r.StartLng,
                endName = r.EndName,
                endLat = r.EndLat,
                endLng = r.EndLng
            })
            .ToList();

        bgRoutesJson = JsonSerializer.Serialize(distinct);
    }
}
<div class="ss-route-bg" aria-hidden="true" data-ss-route-bg>
    <svg class="ss-route-bg-svg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" focusable="false">
        <defs>
            <linearGradient id="ssBgRouteGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="var(--ss-accent)" />
                <stop offset="1" stop-color="var(--ss-primary)" />
            </linearGradient>
            <radialGradient id="ssBgBeam" cx="0" cy="0.5" r="1">
                <stop offset="0" stop-color="var(--ss-accent)" stop-opacity="0.55" />
                <stop offset="1" stop-color="var(--ss-accent)" stop-opacity="0" />
            </radialGradient>
            <filter id="ssBgGlow" x="-40%" y="-40%" width="180%" height="180%">
                <feGaussianBlur stdDeviation="6" result="blur" />
                <feMerge>
                    <feMergeNode in="blur" />
                    <feMergeNode in="SourceGraphic" />
                </feMerge>
            </filter>
            <g id="ssBgCarTemplate">
                <path class="ss-bg-car-beam" d="M16 -6 L70 -22 L70 22 L16 6 Z" fill="url(#ssBgBeam)" />
                <rect class="ss-bg-car-wheel" x="-14" y="-12" width="9" height="5" rx="2" />
                <rect class="ss-bg-car-wheel" x="-14" y="7" width="9" height="5" rx="2" />
                <rect class="ss-bg-car-wheel" x="6" y="-12" width="9" height="5" rx="2" />
                <rect class="ss-bg-car-wheel" x="6" y="7" width="9" height="5" rx="2" />
                <rect class="ss-bg-car-body" x="-18" y="-9" width="36" height="18" rx="7" />
                <path class="ss-bg-car-glass" d="M-2 -7 L11 -5 L11 5 L-2 7 Z" />
                <circle class="ss-bg-car-lamp" cx="16" cy="-5" r="1.8" />
                <circle class="ss-bg-car-lamp" cx="16" cy="5" r="1.8" />
            </g>
        </defs>

        <g class="ss-bg-grid" data-ss-bg-grid></g>
        <g class="ss-bg-routes" data-ss-bg-routes></g>
        <g class="ss-bg-nodes" data-ss-bg-nodes></g>
        <g class="ss-bg-cars" data-ss-bg-cars></g>
    </svg>
    <script type="application/json" data-ss-route-bg-data>@Html.Raw(bgRoutesJson)</script>
</div>
