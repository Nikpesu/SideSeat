@{
    var db = Context.RequestServices.GetService(typeof(SideSeat.Data.SideSeatDbContext)) as SideSeat.Data.SideSeatDbContext;
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
    var returnUrlQuery = Context.Request.Query["returnUrl"].ToString();
    var returnUrl = !string.IsNullOrWhiteSpace(returnUrlQuery) && !returnUrlQuery.Contains("auth=", StringComparison.OrdinalIgnoreCase)
        ? returnUrlQuery
        : Context.Request.Path.ToString();
    var authError = TempData["AuthError"] as string;
    decimal? userSaldo = null;
    if (isAuthenticated && db is not null)
    {
        var userIdClaim = User.FindFirst(SideSeat.Security.SideSeatClaimTypes.KorisnikId)?.Value;
        if (int.TryParse(userIdClaim, out var userId))
        {
            userSaldo = db.Korisnici
                .Where(k => k.Id == userId)
                .Select(k => (decimal?)k.Saldo)
                .FirstOrDefault();
        }
    }
}
<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SideSeat</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/SideSeat.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="ss-header">
        <nav class="navbar navbar-expand-lg ss-nav" aria-label="Glavna navigacija">
            <div class="container-fluid ss-shell">
                <a class="ss-brand" asp-area="" asp-controller="Home" asp-action="Index">SideSeat Transit</a>
                <button class="navbar-toggler ss-nav-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation"
                        aria-controls="mainNavigation" aria-expanded="false" aria-label="Prikazi ili sakrij navigaciju">
                    <span class="ss-nav-toggle-text">Meni</span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavigation">
                    <ul class="navbar-nav ms-lg-3 ss-nav-list">
                        <li class="nav-item">
                            <a class="ss-nav-link @((currentController == "home" && currentAction == "index") ? "active" : string.Empty)"
                               asp-controller="Home" asp-action="Index">Pocetna</a>
                        </li>

                        @if (isAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="ss-nav-link @(currentController == "voznja" && currentAction == "active" ? "active" : string.Empty)"
                                   asp-controller="Voznja" asp-action="Active">Aktivne voznje</a>
                            </li>
                            <li class="nav-item">
                                <a class="ss-nav-link @(currentController == "voznja" && currentAction == "index" ? "active" : string.Empty)"
                                   asp-controller="Voznja" asp-action="Index">Moje voznje</a>
                            </li>
                            <li class="nav-item">
                                <a class="ss-nav-link @(currentController == "rezervacija" ? "active" : string.Empty)"
                                   asp-controller="Rezervacija" asp-action="Index">Rezervacije</a>
                            </li>
                            <li class="nav-item">
                                <a class="ss-nav-link @(currentController == "ocjena" ? "active" : string.Empty)"
                                   asp-controller="Ocjena" asp-action="Index">Ocjene</a>
                            </li>
                            @if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a class="ss-nav-link @(currentController == "grad" ? "active" : string.Empty)"
                                       asp-controller="Grad" asp-action="Index">Gradovi</a>
                                </li>
                                <li class="nav-item">
                                    <a class="ss-nav-link @(currentController == "korisnik" && currentAction != "settings" ? "active" : string.Empty)"
                                       asp-controller="Korisnik" asp-action="Index">Korisnici</a>
                                </li>
                                <li class="nav-item">
                                    <a class="ss-nav-link @(currentController == "vozilo" ? "active" : string.Empty)"
                                       asp-controller="Vozilo" asp-action="Index">Vozila</a>
                                </li>
                                <li class="nav-item">
                                    <a class="ss-nav-link @(currentController == "placanje" ? "active" : string.Empty)"
                                       asp-controller="Placanje" asp-action="Index">Placanja</a>
                                </li>
                            }
                        }
                    </ul>

                    <div class="ms-lg-auto mt-3 mt-lg-0">
                        @if (isAuthenticated)
                        {
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                @if (userSaldo.HasValue)
                                {
                                    <a class="ss-nav-link @(currentController == "korisnik" && currentAction == "saldo" ? "active" : string.Empty)"
                                       asp-controller="Korisnik" asp-action="Saldo">Saldo: @userSaldo.Value.ToString("0.00") EUR</a>
                                }
                                <a class="ss-nav-link @(currentController == "korisnik" && currentAction == "settings" ? "active" : string.Empty)"
                                   asp-controller="Korisnik" asp-action="Settings">@User.Identity!.Name</a>
                                <button type="submit" class="ss-btn ss-btn-secondary">Odjava</button>
                            </form>
                        }
                        else
                        {
                            <div class="d-flex gap-2">
                                <button class="ss-btn ss-btn-secondary" type="button" data-bs-toggle="modal" data-bs-target="#authModal" data-auth-open="login">
                                    Prijava
                                </button>
                                <button class="ss-btn" type="button" data-bs-toggle="modal" data-bs-target="#authModal" data-auth-open="register">
                                    Registracija
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="ss-shell ss-shell-main">
        <main role="main" class="ss-main">
            @RenderBody()
        </main>
    </div>

    <footer class="ss-footer">
        <div class="ss-shell ss-footer-inner">
            <span>&copy; 2026 SideSeat</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy policy</a>
        </div>
    </footer>

    <div class="modal fade ss-auth-modal" id="authModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content ss-auth-shell">
                <div class="ss-auth-header">
                    <div>
                        <span class="ss-auth-kicker">SideSeat</span>
                        <h2>Prijava u mrezu voznji</h2>
                        <p>Upravljaj voznjama, rezervacijama i placanjima u realnom vremenu.</p>
                    </div>
                    <button type="button" class="btn-close ss-auth-close" data-bs-dismiss="modal" aria-label="Zatvori"></button>
                </div>

                <div class="ss-auth-tabs" role="tablist">
                    <button type="button" class="ss-auth-tab is-active" data-auth-tab="login">Prijava</button>
                    <button type="button" class="ss-auth-tab" data-auth-tab="register">Registracija</button>
                </div>

                <div class="ss-auth-body">
                    @if (!string.IsNullOrWhiteSpace(authError))
                    {
                        <div class="ss-auth-alert" role="alert">@authError</div>
                    }
                    <div class="ss-auth-panel is-active" data-auth-panel="login">
                        <form asp-controller="Auth" asp-action="Login" method="post" class="ss-auth-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ReturnUrl" value="@returnUrl" />

                            <div class="mb-3">
                                <label class="form-label" for="auth-login-email">Email</label>
                                <input id="auth-login-email" name="Email" type="email" class="form-control" autocomplete="email" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-login-password">Lozinka</label>
                                <input id="auth-login-password" name="Password" type="password" class="form-control" autocomplete="current-password" required />
                            </div>

                            <div class="form-check mb-3">
                                <input id="auth-login-remember" name="RememberMe" type="checkbox" class="form-check-input" />
                                <label class="form-check-label" for="auth-login-remember">Zapamti me</label>
                            </div>

                            <div class="ss-actions">
                                <button class="ss-btn" type="submit">Prijavi se</button>
                                <button class="ss-btn ss-btn-secondary" type="button" data-auth-tab="register">Kreiraj racun</button>
                            </div>
                            <small class="ss-datetime-help d-block mt-3">
                                Seeded demo credentials:<br />
                                admin@example.com / Admin123!<br />
                                marko@example.com / User123!<br />
                                ivana@example.com / User123!
                            </small>
                        </form>
                        <form asp-controller="Auth" asp-action="ExternalLogin" method="post" class="mt-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="provider" value="Google" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button class="ss-btn ss-btn-secondary w-100" type="submit">Prijava preko Google računa</button>
                        </form>
                    </div>

                    <div class="ss-auth-panel" data-auth-panel="register">
                        <form asp-controller="Auth" asp-action="Register" method="post" class="ss-auth-form">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-email">Email</label>
                                <input id="auth-register-email" name="Email" type="email" class="form-control" autocomplete="email" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-address">Adresa</label>
                                <input id="auth-register-address" name="Address" type="text" class="form-control" autocomplete="street-address" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-phone">Broj mobitela</label>
                                <input id="auth-register-phone" name="PhoneNumber" type="tel" class="form-control" autocomplete="tel" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-oib">OIB</label>
                                <input id="auth-register-oib" name="OIB" type="text" class="form-control" minlength="11" maxlength="11" pattern="[0-9]{11}" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-jmbg">JMBG</label>
                                <input id="auth-register-jmbg" name="JMBG" type="text" class="form-control" minlength="13" maxlength="13" pattern="[0-9]{13}" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-password">Lozinka</label>
                                <input id="auth-register-password" name="Password" type="password" class="form-control" autocomplete="new-password" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-confirm">Ponovi lozinku</label>
                                <input id="auth-register-confirm" name="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" required />
                            </div>

                            <div class="ss-actions">
                                <button class="ss-btn" type="submit">Kreiraj racun</button>
                                <button class="ss-btn ss-btn-secondary" type="button" data-auth-tab="login">Natrag na prijavu</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
