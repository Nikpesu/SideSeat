@using Microsoft.Extensions.Options
@inject IOptions<SideSeat.Services.MapsOptions> MapSettings
@{
    var db = Context.RequestServices.GetService(typeof(SideSeat.Data.SideSeatDbContext)) as SideSeat.Data.SideSeatDbContext;
    var configuration = Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration;
    var useDummyData = configuration?.GetValue<bool>("DUMMY_DATA") == true;
    var appVersion = configuration?["SIDESEAT_VERSION"] ?? "v0.48";
    var googleLoginEnabled =
        !string.IsNullOrWhiteSpace(configuration?["Authentication:Google:ClientId"]) &&
        !string.IsNullOrWhiteSpace(configuration?["Authentication:Google:ClientSecret"]);
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
    var isDriver = User.IsInRole("Driver") || isAdmin;
    var accountName = User.Identity?.Name ?? "Korisnik";
    var accountInitial = accountName.Length > 0 ? accountName[..1].ToUpperInvariant() : "K";
    var returnUrlQuery = Context.Request.Query["returnUrl"].ToString();
    var returnUrl = !string.IsNullOrWhiteSpace(returnUrlQuery) && !returnUrlQuery.Contains("auth=", StringComparison.OrdinalIgnoreCase)
        ? returnUrlQuery
        : Context.Request.Path.ToString();
    var authError = TempData["AuthError"] as string;
    var fundsToastMessage = TempData["FundsToastMessage"] as string;
    var fundsToastHref = TempData["FundsToastHref"] as string;
    int? currentUserId = null;
    decimal? userSaldo = null;
    if (isAuthenticated && db is not null)
    {
        var userIdClaim = User.FindFirst(SideSeat.Security.SideSeatClaimTypes.KorisnikId)?.Value;
        if (int.TryParse(userIdClaim, out var userId))
        {
            currentUserId = userId;
            userSaldo = db.Korisnici
                .Where(k => k.Id == userId)
                .Select(k => (decimal?)k.Saldo)
                .FirstOrDefault();
        }
    }
}
<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SideSeat</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <script>
        (() => {
            try {
                const storedTheme = localStorage.getItem("ss-theme");
                const theme = storedTheme === "light" || storedTheme === "dark"
                    ? storedTheme
                    : (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
                document.documentElement.setAttribute("data-theme", theme);
            } catch {
                document.documentElement.setAttribute("data-theme", "light");
            }
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/leaflet/leaflet.css" />
    <link rel="stylesheet" href="~/SideSeat.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/performative.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/route-maps.css" asp-append-version="true" />
</head>
<body data-page-title="@ViewData["Title"]"
      data-page-controller="@currentController"
      data-map-tile-url="@MapSettings.Value.TileUrl"
      data-map-attribution="@MapSettings.Value.TileAttribution"
      data-map-route-url="/api/maps/route">
    <partial name="_RouteMapBackground" />
    <div class="ss-aurora" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
    </div>
    <div class="ss-sparkle-field" aria-hidden="true">
        <i>✦</i><i>✧</i><i>✦</i><i>·</i><i>✧</i><i>✦</i>
    </div>
    <header class="ss-header">
        <nav class="ss-nav" aria-label="Glavna navigacija">
            <div class="ss-shell ss-nav-primary">
                <div class="ss-nav-brand-group">
                    <button class="ss-menu-trigger"
                            type="button"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#sideNavigation"
                            aria-controls="sideNavigation"
                            aria-label="Otvori glavni meni"
                            data-testid="sidebar-open">
                        <span></span><span></span><span></span>
                    </button>
                    <a class="ss-brand" asp-area="" asp-controller="Home" asp-action="Index" aria-label="SideSeat početna">
                        <img class="ss-brand-mark" src="~/favicon.svg" alt="" width="42" height="42" />
                        <span class="ss-brand-copy">
                            <strong>SideSeat</strong>
                            <small>AI mobility network</small>
                        </span>
                    </a>
                </div>

                @if (isAuthenticated)
                {
                    <button class="ss-search-trigger ss-search-trigger-main"
                            type="button"
                            data-ss-global-search-open
                            aria-haspopup="dialog"
                            data-testid="global-search-trigger">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="11" cy="11" r="7"></circle>
                            <path d="m20 20-3.5-3.5"></path>
                        </svg>
                        <span>Pretraži SideSeat</span>
                        <kbd>Ctrl K</kbd>
                    </button>
                }
                else
                {
                    <span class="ss-nav-search-placeholder" aria-hidden="true"></span>
                }

                <div class="ss-nav-account">
                    <button id="ss-theme-toggle" class="ss-theme-toggle ss-theme-toggle-compact" type="button"
                            aria-label="Promijeni temu" aria-pressed="false">
                        <span class="ss-theme-toggle-icon" aria-hidden="true">☀</span>
                        <span class="ss-theme-toggle-label">Light</span>
                    </button>
                    @if (isAuthenticated)
                    {
                        @await Component.InvokeAsync("ObavijestiBell")
                        <a class="ss-account-link @(currentController == "korisnik" && currentAction == "settings" ? "active" : string.Empty)"
                           asp-controller="Korisnik" asp-action="Settings" data-testid="account-settings">
                            <span class="ss-account-avatar" aria-hidden="true">@accountInitial</span>
                            <span class="ss-account-name">@accountName</span>
                        </a>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="ss-top-logout">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="ss-top-logout-btn" data-testid="top-logout">Odjava</button>
                        </form>
                    }
                    else
                    {
                        <div class="ss-auth-actions">
                            <button class="ss-btn ss-btn-secondary" type="button" data-bs-toggle="modal" data-bs-target="#authModal" data-auth-open="login">
                                Prijava
                            </button>
                            <button class="ss-btn" type="button" data-bs-toggle="modal" data-bs-target="#authModal" data-auth-open="register">
                                Registracija
                            </button>
                        </div>
                    }
                </div>
            </div>

            @if (isAuthenticated)
            {
                <div class="ss-nav-secondary" data-testid="desktop-primary-navigation">
                    <div class="ss-shell ss-nav-secondary-inner">
                        <a class="ss-nav-link @(currentController == "voznja" ? "active" : string.Empty)"
                           asp-controller="Voznja" asp-action="Index" data-testid="nav-rides">Vožnje</a>
                        <a class="ss-nav-link @(currentController == "voznja" && currentAction == "current" ? "active" : string.Empty)"
                           asp-controller="Voznja" asp-action="Current" data-testid="nav-current-ride">Trenutna</a>
                        <a class="ss-nav-link @(currentController == "rezervacija" ? "active" : string.Empty)"
                           asp-controller="Rezervacija" asp-action="Index" data-testid="nav-reservations">Rezervacije</a>
                        <a class="ss-nav-link @(currentController == "ocjena" ? "active" : string.Empty)"
                           asp-controller="Ocjena" asp-action="Index" data-testid="nav-reviews">Ocjene</a>
                        @if (userSaldo.HasValue)
                        {
                            <a class="ss-nav-link ss-nav-balance @(currentController == "korisnik" && currentAction == "saldo" ? "active" : string.Empty)"
                               asp-controller="Korisnik" asp-action="Saldo" data-testid="nav-balance">
                                Saldo: <strong>@userSaldo.Value.ToString("0.00") EUR</strong>
                            </a>
                        }
                    </div>
                </div>
            }
        </nav>
    </header>

    <aside class="offcanvas offcanvas-start ss-sidebar"
           tabindex="-1"
           id="sideNavigation"
           aria-labelledby="sideNavigationTitle"
           data-testid="sidebar">
        <div class="offcanvas-header ss-sidebar-header">
            <a class="ss-brand" asp-controller="Home" asp-action="Index">
                <img class="ss-brand-mark" src="~/favicon.svg" alt="" width="40" height="40" />
                <span class="ss-brand-copy">
                    <strong id="sideNavigationTitle">SideSeat</strong>
                    <small>Glavni meni</small>
                </span>
            </a>
            <button type="button" class="btn-close ss-sidebar-close" data-bs-dismiss="offcanvas" aria-label="Zatvori meni"></button>
        </div>
        <div class="offcanvas-body ss-sidebar-body">
            <details class="ss-sidebar-group" open>
                <summary>Glavno</summary>
                <nav aria-label="Glavne stranice">
                    <a class="ss-sidebar-link @((currentController == "home" && currentAction == "index") ? "active" : string.Empty)"
                       asp-controller="Home" asp-action="Index" data-testid="sidebar-home">Početna</a>
                    @if (isAuthenticated)
                    {
                        <a class="ss-sidebar-link @(currentController == "voznja" && currentAction != "active" ? "active" : string.Empty)"
                           asp-controller="Voznja" asp-action="Index">Vožnje</a>
                        <a class="ss-sidebar-link @(currentController == "voznja" && currentAction == "active" ? "active" : string.Empty)"
                           asp-controller="Voznja" asp-action="Active">Aktivne vožnje</a>
                        @if (isDriver)
                        {
                            <a class="ss-sidebar-link @(currentController == "voznja" && currentAction == "current" ? "active" : string.Empty)"
                               asp-controller="Voznja" asp-action="Current">Trenutna vožnja</a>
                        }
                        <a class="ss-sidebar-link @(currentController == "rezervacija" && !currentAction.StartsWith("admin") ? "active" : string.Empty)"
                           asp-controller="Rezervacija" asp-action="Index">Rezervacije</a>
                        <a class="ss-sidebar-link @(currentController == "ocjena" && currentAction != "attachments" ? "active" : string.Empty)"
                           asp-controller="Ocjena" asp-action="Index">Ocjene</a>
                    }
                </nav>
            </details>

            @if (isAuthenticated)
            {
                <details class="ss-sidebar-group" @(currentAction is "create" or "uplata" ? "open" : null)>
                    <summary>Akcije</summary>
                    <nav aria-label="Brze akcije">
                        @if (isDriver)
                        {
                            <a class="ss-sidebar-link @(currentController == "voznja" && currentAction == "create" ? "active" : string.Empty)"
                               asp-controller="Voznja" asp-action="Create" data-testid="sidebar-create-ride">Nova vožnja</a>
                        }
                        <a class="ss-sidebar-link @(currentController == "korisnik" && currentAction == "uplata" ? "active" : string.Empty)"
                           asp-controller="Korisnik" asp-action="Uplata">Uplati sredstva</a>
                    </nav>
                </details>

                <details class="ss-sidebar-group" @(currentController == "korisnik" ? "open" : null)>
                    <summary>Račun</summary>
                    <nav aria-label="Korisnički račun">
                        @if (userSaldo.HasValue)
                        {
                            <a class="ss-sidebar-link ss-sidebar-balance @(currentController == "korisnik" && currentAction == "saldo" ? "active" : string.Empty)"
                               asp-controller="Korisnik" asp-action="Saldo">
                                <span>Saldo</span>
                                <strong>@userSaldo.Value.ToString("0.00") EUR</strong>
                            </a>
                        }
                        @if (currentUserId.HasValue)
                        {
                            <a class="ss-sidebar-link @(currentController == "korisnik" && currentAction == "details" ? "active" : string.Empty)"
                               asp-controller="Korisnik" asp-action="Details" asp-route-id="@currentUserId.Value">Moj profil</a>
                        }
                        <a class="ss-sidebar-link @(currentController == "korisnik" && currentAction == "settings" ? "active" : string.Empty)"
                           asp-controller="Korisnik" asp-action="Settings">Postavke</a>
                        <a class="ss-sidebar-link @(currentController == "korisnik" && currentAction == "kyc" ? "active" : string.Empty)"
                           asp-controller="Korisnik" asp-action="Kyc">KYC vozača</a>
                    </nav>
                </details>
            }

            @if (isAdmin)
            {
                <details class="ss-sidebar-group ss-sidebar-admin"
                         @(currentController is "audit" or "grad" or "placanje" or "vozilo" ||
                           (currentController == "korisnik" && currentAction is "index" or "create" or "edit" or "delete") ||
                           (currentController == "rezervacija" && currentAction.StartsWith("admin")) ||
                           (currentController == "ocjena" && currentAction is "attachments" or "adminfeedback" or "adminedit" or "admindelete")
                             ? "open"
                             : null)
                         data-testid="sidebar-admin">
                    <summary>Administracija</summary>
                    <nav aria-label="Administracija">
                        <a class="ss-sidebar-link @(currentController == "korisnik" && currentAction == "index" ? "active" : string.Empty)"
                           asp-controller="Korisnik" asp-action="Index" data-testid="sidebar-admin-users">Korisnici</a>
                        <a class="ss-sidebar-link @(currentController == "korisnik" && currentAction == "create" ? "active" : string.Empty)"
                           asp-controller="Korisnik" asp-action="Create">Novi korisnik</a>
                        <a class="ss-sidebar-link @(currentController == "grad" ? "active" : string.Empty)"
                           asp-controller="Grad" asp-action="Index">Gradovi</a>
                        <a class="ss-sidebar-link @(currentController == "grad" && currentAction == "create" ? "active" : string.Empty)"
                           asp-controller="Grad" asp-action="Create">Novi grad</a>
                        <a class="ss-sidebar-link @(currentController == "vozilo" ? "active" : string.Empty)"
                           asp-controller="Vozilo" asp-action="Index">Vozila</a>
                        <a class="ss-sidebar-link @(currentController == "vozilo" && currentAction == "create" ? "active" : string.Empty)"
                           asp-controller="Vozilo" asp-action="Create">Novo vozilo</a>
                        <a class="ss-sidebar-link @(currentController == "rezervacija" && currentAction == "index" ? "active" : string.Empty)"
                           asp-controller="Rezervacija" asp-action="Index">Sve rezervacije</a>
                        <a class="ss-sidebar-link @(currentController == "rezervacija" && currentAction.StartsWith("admin") ? "active" : string.Empty)"
                           asp-controller="Rezervacija" asp-action="AdminCreate">Nova rezervacija</a>
                        <a class="ss-sidebar-link @(currentController == "placanje" ? "active" : string.Empty)"
                           asp-controller="Placanje" asp-action="Index">Plaćanja</a>
                        <a class="ss-sidebar-link @(currentController == "placanje" && currentAction == "create" ? "active" : string.Empty)"
                           asp-controller="Placanje" asp-action="Create">Novo plaćanje</a>
                        <a class="ss-sidebar-link @(currentController == "ocjena" && currentAction == "index" ? "active" : string.Empty)"
                           asp-controller="Ocjena" asp-action="Index">Sve ocjene</a>
                        <a class="ss-sidebar-link @(currentController == "ocjena" && currentAction == "attachments" ? "active" : string.Empty)"
                           asp-controller="Ocjena" asp-action="Attachments">Prilozi ocjena</a>
                        <a class="ss-sidebar-link @(currentController == "audit" ? "active" : string.Empty)"
                           asp-controller="Audit" asp-action="Index">Audit zapis</a>
                    </nav>
                </details>
            }

            <details class="ss-sidebar-group">
                <summary>Ostalo</summary>
                <nav aria-label="Ostale mogućnosti">
                    <button class="ss-sidebar-link ss-sidebar-button" type="button" data-ss-theme-toggle>
                        Promijeni temu
                    </button>
                    <a class="ss-sidebar-link @(currentController == "home" && currentAction == "vodic" ? "active" : string.Empty)"
                       asp-controller="Home" asp-action="Vodic">Vodič kroz vožnju</a>
                    <a class="ss-sidebar-link @(currentController == "home" && currentAction == "privacy" ? "active" : string.Empty)"
                       asp-controller="Home" asp-action="Privacy">Privacy</a>
                    @if (isAuthenticated)
                    {
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="ss-sidebar-logout">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="ss-sidebar-link ss-sidebar-button" data-testid="sidebar-logout">Odjava</button>
                        </form>
                    }
                    else
                    {
                        <button class="ss-sidebar-link ss-sidebar-button" type="button"
                                data-bs-toggle="modal" data-bs-target="#authModal" data-auth-open="login"
                                data-bs-dismiss="offcanvas">Prijava</button>
                        <button class="ss-sidebar-link ss-sidebar-button" type="button"
                                data-bs-toggle="modal" data-bs-target="#authModal" data-auth-open="register"
                                data-bs-dismiss="offcanvas">Registracija</button>
                    }
                </nav>
            </details>
        </div>
        <footer class="ss-sidebar-footer">
            <span>Verzija @appVersion</span>
            @if (isAuthenticated)
            {
                <span>@accountName</span>
            }
        </footer>
    </aside>

    <div class="ss-shell ss-shell-main">
        <main role="main" class="ss-main">
            @RenderBody()
        </main>
    </div>

    <footer class="ss-footer">
        <div class="ss-shell ss-footer-inner">
            <span>&copy; 2026 SideSeat · Built for movement at machine speed</span>
            <span class="ss-footer-links">
                <span>Verzija @appVersion</span>
                <a asp-area="" asp-controller="Home" asp-action="Vodic">Vodič kroz vožnju</a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy policy</a>
            </span>
        </div>
    </footer>

    <partial name="_AiAssistant" />
    @if (isAuthenticated)
    {
        @await Component.InvokeAsync("RideChatDock")
    }

    <aside class="ss-route-preview"
           data-ss-route-preview
           aria-label="Pregled rute"
           hidden>
        <header class="ss-route-preview-header">
            <div>
                <span class="ss-kicker">Pregled rute</span>
                <strong data-ss-route-preview-label>Ruta</strong>
            </div>
            <button type="button"
                    class="ss-route-preview-close"
                    data-ss-route-preview-close
                    aria-label="Zatvori pregled rute">×</button>
        </header>
        <div class="ss-route-map-canvas" data-ss-route-map-canvas></div>
        <p class="ss-route-map-fallback" data-ss-route-map-fallback hidden>
            Koordinate rute nisu dostupne.
        </p>
    </aside>

    @if (isAuthenticated)
    {
        <div class="ss-command-palette" data-ss-global-search hidden>
            <button class="ss-command-backdrop" type="button" data-ss-global-search-close aria-label="Zatvori pretragu"></button>
            <section class="ss-command-dialog" role="dialog" aria-modal="true" aria-labelledby="ss-command-title">
                <header>
                    <div>
                        <span class="ss-kicker">Global search</span>
                        <h2 id="ss-command-title">Pretraži SideSeat</h2>
                    </div>
                    <button class="ss-command-close" type="button" data-ss-global-search-close aria-label="Zatvori">×</button>
                </header>
                <label class="visually-hidden" for="ss-global-search-input">Pojam pretrage</label>
                <input id="ss-global-search-input"
                       class="form-control"
                       type="search"
                       autocomplete="off"
                       placeholder="Stranice, vožnje, rezervacije..."
                       data-ss-global-search-input />
                <div class="ss-command-results" data-ss-global-search-results aria-live="polite">
                    <p>Upiši najmanje dva znaka.</p>
                </div>
            </section>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(fundsToastMessage))
    {
        <aside class="ss-toast ss-toast-danger" role="alert" aria-live="assertive">
            <div>
                <strong>Nedovoljno sredstava</strong>
                <p>@fundsToastMessage</p>
            </div>
            <a class="ss-toast-action" href="@fundsToastHref">Uplati sredstva</a>
        </aside>
    }

    <div class="modal fade ss-auth-modal" id="authModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content ss-auth-shell">
                <div class="ss-auth-header">
                    <div>
                        <span class="ss-auth-kicker">SideSeat</span>
                        <h2>Prijava u mrezu voznji</h2>
                        <p>Upravljaj voznjama, rezervacijama i placanjima u realnom vremenu.</p>
                    </div>
                    <button type="button" class="btn-close ss-auth-close" data-bs-dismiss="modal" aria-label="Zatvori"></button>
                </div>

                <div class="ss-auth-tabs" role="tablist">
                    <button type="button" class="ss-auth-tab is-active" data-auth-tab="login">Prijava</button>
                    <button type="button" class="ss-auth-tab" data-auth-tab="register">Registracija</button>
                </div>

                <div class="ss-auth-body">
                    @if (!string.IsNullOrWhiteSpace(authError))
                    {
                        <div class="ss-auth-alert" role="alert">@authError</div>
                    }
                    <div class="ss-auth-panel is-active" data-auth-panel="login">
                        <form asp-controller="Auth" asp-action="Login" method="post" class="ss-auth-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ReturnUrl" value="@returnUrl" />

                            <div class="mb-3">
                                <label class="form-label" for="auth-login-email">Email</label>
                                <input id="auth-login-email" name="Email" type="email" class="form-control" autocomplete="email" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-login-password">Lozinka</label>
                                <input id="auth-login-password" name="Password" type="password" class="form-control" autocomplete="current-password" required />
                            </div>

                            <div class="form-check mb-3">
                                <input id="auth-login-remember" name="RememberMe" type="checkbox" value="true" class="form-check-input" />
                                <input name="RememberMe" type="hidden" value="false" />
                                <label class="form-check-label" for="auth-login-remember">Zapamti me</label>
                            </div>

                            <div class="ss-actions">
                                <button class="ss-btn" type="submit">Prijavi se</button>
                                <button class="ss-btn ss-btn-secondary" type="button" data-auth-tab="register">Kreiraj racun</button>
                            </div>
                            @if (useDummyData)
                            {
                                <small class="ss-datetime-help d-block mt-3">
                                    Demo korisnici:<br />
                                    admin@example.com / Admin123!<br />
                                    marko@example.com / User123!<br />
                                    ivana@example.com / User123!
                                </small>
                            }
                        </form>
                        @if (googleLoginEnabled)
                        {
                            <form asp-controller="Auth" asp-action="ExternalLogin" method="post" class="mt-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="provider" value="Google" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button class="ss-google-btn w-100" type="submit">
                                    <svg class="ss-google-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path class="ss-google-icon-blue" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                                        <path class="ss-google-icon-green" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C4 20.53 7.7 23 12 23z" />
                                        <path class="ss-google-icon-yellow" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.84z" />
                                        <path class="ss-google-icon-red" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 4 3.47 2.18 7.06L5.84 9.9C6.71 7.3 9.14 5.38 12 5.38z" />
                                    </svg>
                                    <span>Nastavi s Google računom</span>
                                </button>
                            </form>
                        }
                    </div>

                    <div class="ss-auth-panel" data-auth-panel="register">
                        <form asp-controller="Auth" asp-action="Register" method="post" class="ss-auth-form">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-email">Email</label>
                                <input id="auth-register-email" name="Email" type="email" class="form-control" autocomplete="email" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-address">Adresa</label>
                                <input id="auth-register-address" name="Address" type="text" class="form-control" autocomplete="street-address" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-phone">Broj mobitela</label>
                                <input id="auth-register-phone" name="PhoneNumber" type="tel" class="form-control" autocomplete="tel" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-oib">OIB</label>
                                <input id="auth-register-oib" name="OIB" type="text" class="form-control" minlength="11" maxlength="11" pattern="[0-9]{11}" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-jmbg">JMBG</label>
                                <input id="auth-register-jmbg" name="JMBG" type="text" class="form-control" minlength="13" maxlength="13" pattern="[0-9]{13}" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-password">Lozinka</label>
                                <input id="auth-register-password" name="Password" type="password" class="form-control" autocomplete="new-password" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="auth-register-confirm">Ponovi lozinku</label>
                                <input id="auth-register-confirm" name="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" required />
                            </div>

                            <div class="ss-actions">
                                <button class="ss-btn" type="submit">Kreiraj racun</button>
                                <button class="ss-btn ss-btn-secondary" type="button" data-auth-tab="login">Natrag na prijavu</button>
                            </div>
                        </form>
                        @if (googleLoginEnabled)
                        {
                            <form asp-controller="Auth" asp-action="ExternalLogin" method="post" class="mt-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="provider" value="Google" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button class="ss-google-btn w-100" type="submit">
                                    <svg class="ss-google-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path class="ss-google-icon-blue" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                                        <path class="ss-google-icon-green" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C4 20.53 7.7 23 12 23z" />
                                        <path class="ss-google-icon-yellow" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.84z" />
                                        <path class="ss-google-icon-red" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 4 3.47 2.18 7.06L5.84 9.9C6.71 7.3 9.14 5.38 12 5.38z" />
                                    </svg>
                                    <span>Nastavi s Google računom</span>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/leaflet/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/route-maps.js" asp-append-version="true"></script>
    <script src="~/js/route-background.js" asp-append-version="true" defer></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
