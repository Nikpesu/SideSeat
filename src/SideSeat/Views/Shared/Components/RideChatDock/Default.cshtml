@model List<SideSeat.ViewComponents.RideChatDockItem>

@if (Model.Count > 0)
{
    <aside class="ss-rcd" data-ss-ridechat>
        <section class="ss-rcd-panel" data-ss-rcd-panel role="dialog" aria-label="Chat vožnje" hidden>
            <header class="ss-rcd-header">
                <strong>Chat vožnje</strong>
                <button type="button" class="ss-rcd-close" data-ss-rcd-close aria-label="Zatvori chat">×</button>
            </header>
            <label class="visually-hidden" for="ss-rcd-select">Odaberi vožnju</label>
            <select id="ss-rcd-select" class="form-select ss-rcd-select" data-ss-rcd-select>
                @foreach (var ride in Model)
                {
                    <option value="@ride.Id">@ride.Label</option>
                }
            </select>
            <div class="ss-rcd-log" data-ss-rcd-log aria-live="polite"></div>
            <form class="ss-rcd-form" data-ss-rcd-form>
                <select class="form-select" data-ss-rcd-recipient aria-label="Primatelj poruke">
                    <option value="">Cijela vožnja</option>
                </select>
                <input class="form-control" data-ss-rcd-input maxlength="1000" placeholder="Poruka..." autocomplete="off" />
                <button type="submit" class="ss-btn ss-chat-send" title="Pošalji (Enter)" aria-label="Pošalji (Enter)">⏎</button>
            </form>
        </section>
        <button type="button" class="ss-rcd-fab" data-ss-rcd-toggle aria-expanded="false">
            <span class="ss-rcd-fab-icon" aria-hidden="true">💬</span>
            <span class="ss-rcd-fab-copy">
                <strong>Chat vožnje</strong>
                <small>@Model.Count @(Model.Count == 1 ? "vožnja" : "vožnji")</small>
            </span>
        </button>
    </aside>
}
