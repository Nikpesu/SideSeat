@model SideSeat.Models.Home.HomeDashboardViewModel
@using SideSeat.Models.ViewModels
@{
    ViewData["Title"] = "Pocetna";
    var isAuthenticated = Model.IsAuthenticated;
    var fromLookup = new AutocompleteLookupViewModel
    {
        Name = "from",
        Label = "Polaziste",
        Endpoint = Url.Action("SearchRouteLocations", "Home") ?? string.Empty,
        SelectedId = Model.SearchFrom?.ToString() ?? string.Empty,
        SelectedText = Model.SearchFromText,
        Placeholder = "Odaberi polaziste...",
        HelpText = "Odaberi polaziste ili ostavi prazno za sve destinacije.",
        MinimumLength = 0,
        RouteMode = "from",
        RoutePeerName = "to"
    };
    var toLookup = new AutocompleteLookupViewModel
    {
        Name = "to",
        Label = "Odrediste",
        Endpoint = Url.Action("SearchRouteLocations", "Home") ?? string.Empty,
        SelectedId = Model.SearchTo?.ToString() ?? string.Empty,
        SelectedText = Model.SearchToText,
        Placeholder = "Odaberi odrediste...",
        HelpText = "Odaberi odrediste ili ostavi prazno za sve destinacije.",
        MinimumLength = 0,
        RouteMode = "to",
        RoutePeerName = "from"
    };
    var searchDateInput = new DateTimeInputViewModel
    {
        Name = "date",
        Label = "Datum",
        Value = Model.SearchDate,
        DateOnly = true
    };
}

<section class="ss-page ss-home-hub">
    <div class="ss-home-content">
        <nav class="ss-breadcrumb" aria-label="Breadcrumb">
            <span class="current" aria-current="page">Pocetna</span>
        </nav>

        <div class="ss-hero ss-holo-hero">
            <div class="ss-holo-copy">
                <span class="ss-hero-kicker"><span>✦</span> The intelligence layer for shared mobility</span>
                <h1>
                    Svaka ruta.
                    <span class="ss-gradient-text" data-ss-word-roll data-words="Predviđena.,Povezana.,Optimizirana.,SideSeat.">SideSeat.</span>
                </h1>
                <p>
                    AI-native platforma koja pretvara vožnje, rezervacije i povjerenje u jedan
                    fluidan mobility operating system. Manje trenja. Više kretanja. Dramatično bolji pitch deck.
                </p>
                <form class="ss-prompt-hero" data-ss-ai-launch-form>
                    <span aria-hidden="true">✦</span>
                    <label class="visually-hidden" for="ss-home-ai-prompt">Pitaj SideSeat AI</label>
                    <input id="ss-home-ai-prompt" type="text" placeholder="Pitaj AI: pronađi mi najbolju vožnju za sutra..." autocomplete="off" />
                    <button type="submit" aria-label="Otvori SideSeat AI">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12 14-7-4.5 14-3-5.5L5 12Zm6.5 1.5L19 5" /></svg>
                    </button>
                </form>
                <form class="ss-search" method="get" asp-controller="Home" asp-action="Index" aria-label="Pretrazi voznje" data-ss-ajax-form data-ss-ajax-target="[data-ss-home-search-results]">
                    <div class="ss-search-grid">
                        <div>
                            <partial name="_AutocompleteLookup" model="fromLookup" />
                        </div>
                        <div>
                            <partial name="_AutocompleteLookup" model="toLookup" />
                        </div>
                        <div>
                            <partial name="_DateTimeInput" model="searchDateInput" />
                        </div>
                        <div class="ss-search-cta">
                            <button class="ss-btn" type="submit">Pretrazi</button>
                        </div>
                    </div>
                </form>
                <div class="ss-actions">
                    <a class="ss-btn" asp-controller="Voznja" asp-action="Active">Pronadi voznju</a>
                    @if (isAuthenticated)
                    {
                        <a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Create">Objavi voznju</a>
                    }
                    else
                    {
                        <button class="ss-btn ss-btn-ghost" type="button" data-bs-toggle="modal" data-bs-target="#authModal" data-auth-open="login">
                            Prijava
                        </button>
                        <button class="ss-btn ss-btn-ghost" type="button" data-bs-toggle="modal" data-bs-target="#authModal" data-auth-open="register">
                            Registracija
                        </button>
                    }
                </div>
                <div class="ss-hero-meta">
                    <div class="ss-hero-metric">
                        <span class="ss-hero-label"><i></i> Aktivne vožnje</span>
                        <span class="ss-hero-value" data-ss-counter="@Model.BrojAktivnihVoznji">@Model.BrojAktivnihVoznji</span>
                    </div>
                    <div class="ss-hero-metric">
                        <span class="ss-hero-label"><i></i> Rezervacije</span>
                        <span class="ss-hero-value" data-ss-counter="@Model.BrojRezervacija">@Model.BrojRezervacija</span>
                    </div>
                    <div class="ss-hero-metric">
                        <span class="ss-hero-label"><i></i> Trust signals</span>
                        <span class="ss-hero-value" data-ss-counter="@Model.BrojOcjena">@Model.BrojOcjena</span>
                    </div>
                </div>
            </div>

            <div class="ss-holo-board" aria-hidden="true">
                @if (Model.NadolazeceVoznje.Count == 0)
                {
                    <div class="ss-holo-row">
                        <span class="ss-holo-time">--:--</span>
                        <span class="ss-holo-route">Nema planiranih voznji</span>
                        <span class="ss-holo-status">Idle</span>
                    </div>
                }
                else
                {
                    foreach (var voznja in Model.NadolazeceVoznje)
                    {
                        <div class="ss-holo-row">
                            <span class="ss-holo-time">@voznja.Polazak.ToLocalTime().ToString("HH:mm")</span>
                            <span class="ss-holo-route">@voznja.PolazniGrad - @voznja.OdredisniGrad</span>
                            <span class="ss-holo-status is-live">Planirana</span>
                        </div>
                    }
                }
                <div class="ss-holo-pulse"></div>
            </div>
        </div>

        <div class="ss-capability-marquee" aria-label="SideSeat capabilities">
            <div>
                <span>ROUTE INTELLIGENCE</span><b>✦</b>
                <span>REAL-TIME CAPACITY</span><b>✦</b>
                <span>HUMAN TRUST GRAPH</span><b>✦</b>
                <span>PAYMENT ORCHESTRATION</span><b>✦</b>
                <span>AI COPILOT</span><b>✦</b>
                <span>ROUTE INTELLIGENCE</span><b>✦</b>
                <span>REAL-TIME CAPACITY</span><b>✦</b>
                <span>HUMAN TRUST GRAPH</span><b>✦</b>
                <span>PAYMENT ORCHESTRATION</span><b>✦</b>
                <span>AI COPILOT</span><b>✦</b>
            </div>
        </div>

        <div class="ss-search-results" aria-live="polite" data-ss-home-search-results>
            <div class="ss-search-head">
                <h2>Vozni red</h2>
                <span>@Model.SearchResults.Count prikazanih voznji</span>
            </div>

            @if (Model.SearchResults.Count == 0)
            {
                <div class="ss-empty">Jos nema rezultata. Unesi polaziste, odrediste ili datum.</div>
            }
            else
            {
                <div class="ss-ride-grid">
                    @foreach (var voznja in Model.SearchResults)
                    {
                        <article class="ss-ride-card">
                            <div class="ss-ride-route">
                                <span>@voznja.PolazniGrad</span>
                                <span class="ss-ride-arrow">→</span>
                                <span>@voznja.OdredisniGrad</span>
                            </div>
                            <div class="ss-ride-meta">
                                <span>@voznja.Polazak.ToLocalTime().ToString("dd.MM. HH:mm")</span>
                                <span>@voznja.SlobodnaMjesta mjesta</span>
                                <span>@voznja.CijenaPoMjestu.ToString("0.00") €</span>
                            </div>
                            <div class="ss-ride-driver">@voznja.Vozac</div>
                            <a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Details" asp-route-id="@voznja.Id">Detalji</a>
                        </article>
                    }
                </div>
            }
        </div>

        <div class="ss-home-capabilities" aria-label="Mogucnosti aplikacije">
            <article class="ss-cap-card">
                <span class="ss-cap-icon">01</span>
                <h2>Planiranje i objava</h2>
                <p>Definiraj rutu, cijenu i broj mjesta, a aplikacija automatski vodi evidenciju dostupnosti.</p>
                @if (isAuthenticated)
                {
                    <a class="ss-link" asp-controller="Voznja" asp-action="Create">Objavi novu voznju</a>
                }
            </article>
            <article class="ss-cap-card">
                <span class="ss-cap-icon">02</span>
                <h2>Rezervacije u letu</h2>
                <p>Putnici vide aktivne rute, potvrduju mjesto i primaju azuriranja bez dodatnih poziva.</p>
                <a class="ss-link" asp-controller="Rezervacija" asp-action="Index">Upravljaj rezervacijama</a>
            </article>
            <article class="ss-cap-card">
                <span class="ss-cap-icon">03</span>
                <h2>Ocjene i povjerenje</h2>
                <p>Ocjene voznji i korisnika stvaraju transparentnu mrezu pouzdanih voznji.</p>
                <a class="ss-link" asp-controller="Ocjena" asp-action="Index">Pogledaj ocjene</a>
            </article>
        </div>

        <div class="ss-home-flow" aria-label="Kako radi">
            <div class="ss-flow-step">
                <span class="ss-flow-index">01</span>
                <div>
                    <h3>Odaberi ulogu</h3>
                    <p>Putnik ili vozac, SideSeat prilagodava prikaz za tvoju rutinu.</p>
                </div>
            </div>
            <div class="ss-flow-step">
                <span class="ss-flow-index">02</span>
                <div>
                    <h3>Prati hologram</h3>
                    <p>Vizualni raspored prikazuje raspolozive voznje, mjesta i status u realnom vremenu.</p>
                </div>
            </div>
            <div class="ss-flow-step">
                <span class="ss-flow-index">03</span>
                <div>
                    <h3>Rezerviraj ili potvrdi</h3>
                    <p>Brza potvrda rezervacija i placanja bez napustanja platforme.</p>
                </div>
            </div>
        </div>
    </div>

</section>

