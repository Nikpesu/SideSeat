@model SideSeat.Models.Lab2.Lab2DashboardViewModel
@{
    ViewData["Title"] = "Pocetna";
}

<section class="ss-page ss-home-hub">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <span class="current" aria-current="page">Pocetna</span>
    </nav>

    <div class="ss-hero ss-hero-home">
        <span class="ss-hero-kicker">BlaBlaCar inspired flow</span>
        <h1>Putuj ili vozi bez kompliciranja</h1>
        <p>
            Jedan profil, dvije uloge: kao putnik pronadi voznju, a kao vozac objavi svoju rutu.
            Ispod je command deck za sve operativne stranice aplikacije.
        </p>
        <div class="ss-actions">
            <a class="ss-btn" asp-controller="Voznja" asp-action="Active">Pronadi voznju</a>
            <a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Create">Objavi voznju</a>
        </div>
    </div>

    <div class="ss-role-grid" aria-label="Uloge korisnika">
        <article class="ss-role-card">
            <div class="ss-role-head">
                <span class="ss-role-tag">Putnik mode</span>
                <h2>Trebas prijevoz?</h2>
            </div>
            <p>Fokus na brzo pronalazenje aktivnih voznji i rezervaciju mjesta.</p>
            <ul class="ss-role-list">
                <li>Pregledaj rute i vremena polaska.</li>
                <li>Provjeri slobodna mjesta i cijene.</li>
                <li>Upravljaj svojim rezervacijama i placanjima.</li>
            </ul>
            <div class="ss-actions">
                <a class="ss-btn" asp-controller="Voznja" asp-action="Active">Aktivne voznje</a>
                <a class="ss-btn ss-btn-secondary" asp-controller="Rezervacija" asp-action="Index">Moje rezervacije</a>
            </div>
        </article>

        <article class="ss-role-card">
            <div class="ss-role-head">
                <span class="ss-role-tag">Vozac mode</span>
                <h2>Nudis prijevoz?</h2>
            </div>
            <p>Fokus na objavu voznje, popunjavanje mjesta i pracenje izvedbe voznji.</p>
            <ul class="ss-role-list">
                <li>Kreiraj novu voznju i definiraj cijenu.</li>
                <li>Prati status voznji i rezervirana mjesta.</li>
                <li>Azuriraj rutu i vrijeme kad se plan promijeni.</li>
            </ul>
            <div class="ss-actions">
                <a class="ss-btn" asp-controller="Voznja" asp-action="Create">Nova voznja</a>
                <a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Index">Upravljanje voznjama</a>
            </div>
        </article>
    </div>

    <div class="ss-page-head">
        <h2>Transit command deck</h2>
        <p>Operativni pregled svih glavnih sekcija i direktni ulaz na Index/Details tokove.</p>
    </div>

    <div class="ss-home-grid" aria-label="Lab 2 sekcije">
        <a class="ss-home-card" asp-controller="Voznja" asp-action="Index">
            <span class="ss-home-label">Voznje</span>
            <strong class="ss-home-count">@Model.BrojVoznji</strong>
            <span class="ss-home-hint">Kontrola ruta, statusa i slobodnih mjesta</span>
        </a>
        <a class="ss-home-card" asp-controller="Voznja" asp-action="Active">
            <span class="ss-home-label">Aktivne voznje</span>
            <strong class="ss-home-count">@Model.BrojVoznji</strong>
            <span class="ss-home-hint">Filtriraj i otvori detalje aktivnih polazaka</span>
        </a>
        <a class="ss-home-card" asp-controller="Rezervacija" asp-action="Index">
            <span class="ss-home-label">Rezervacije</span>
            <strong class="ss-home-count">@Model.BrojRezervacija</strong>
            <span class="ss-home-hint">Potvrde, statusi i broj mjesta po rezervaciji</span>
        </a>
        <a class="ss-home-card" asp-controller="Placanje" asp-action="Index">
            <span class="ss-home-label">Placanja</span>
            <strong class="ss-home-count">@Model.BrojPlacanja</strong>
            <span class="ss-home-hint">Status uplata i nacini placanja po rezervaciji</span>
        </a>
        <a class="ss-home-card" asp-controller="Ocjena" asp-action="Index">
            <span class="ss-home-label">Ocjene</span>
            <strong class="ss-home-count">@Model.BrojOcjena</strong>
            <span class="ss-home-hint">Povratne informacije nakon voznje</span>
        </a>
        <a class="ss-home-card" asp-controller="Korisnik" asp-action="Index">
            <span class="ss-home-label">Korisnici</span>
            <strong class="ss-home-count">@Model.BrojKorisnika</strong>
            <span class="ss-home-hint">Profili putnika i vozaca te njihov status</span>
        </a>
        <a class="ss-home-card" asp-controller="Vozilo" asp-action="Index">
            <span class="ss-home-label">Vozila</span>
            <strong class="ss-home-count">@Model.BrojVozila</strong>
            <span class="ss-home-hint">Vozni park i povezana vozaceva vozila</span>
        </a>
        <a class="ss-home-card" asp-controller="Grad" asp-action="Index">
            <span class="ss-home-label">Gradovi</span>
            <strong class="ss-home-count">@Model.BrojGradova</strong>
            <span class="ss-home-hint">Polazne i odredisne tocke svih ruta</span>
        </a>
    </div>
</section>
