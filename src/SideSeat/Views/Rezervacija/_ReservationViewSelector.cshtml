@model SideSeat.Models.ViewModels.RezervacijaListViewModel

<nav class="ss-ride-selector" aria-label="Vrsta pregleda rezervacija">
    @if (Model.IsAdmin)
    {
        <a class="ss-ride-selector-link @(Model.SelectedView == "all" ? "is-active" : string.Empty)"
           asp-controller="Rezervacija" asp-action="Index" asp-route-view="all" asp-route-status="@Model.SelectedStatus">Sve rezervacije</a>
    }
    <a class="ss-ride-selector-link @(Model.SelectedView == "mine" ? "is-active" : string.Empty)"
       asp-controller="Rezervacija" asp-action="Index" asp-route-view="mine" asp-route-status="@Model.SelectedStatus">Moje rezervacije</a>
    @if (Model.CanViewRideReservations)
    {
        <a class="ss-ride-selector-link @(Model.SelectedView == "my-rides" ? "is-active" : string.Empty)"
           asp-controller="Rezervacija" asp-action="Index" asp-route-view="my-rides" asp-route-status="@Model.SelectedStatus">Rezervacije mojih voznji</a>
    }
</nav>

<nav class="ss-ride-selector" aria-label="Status rezervacija">
    <a class="ss-ride-selector-link @(Model.SelectedStatus == "all" ? "is-active" : string.Empty)"
       asp-controller="Rezervacija" asp-action="Index" asp-route-view="@Model.SelectedView" asp-route-status="all">Sve <span class="ss-selector-count">@Model.AllCount</span></a>
    <a class="ss-ride-selector-link @(Model.SelectedStatus == "pending" ? "is-active" : string.Empty)"
       asp-controller="Rezervacija" asp-action="Index" asp-route-view="@Model.SelectedView" asp-route-status="pending">U procesu potvrde <span class="ss-selector-count">@Model.PendingCount</span></a>
    <a class="ss-ride-selector-link @(Model.SelectedStatus == "confirmed" ? "is-active" : string.Empty)"
       asp-controller="Rezervacija" asp-action="Index" asp-route-view="@Model.SelectedView" asp-route-status="confirmed">Potvrđene <span class="ss-selector-count">@Model.ConfirmedCount</span></a>
    <a class="ss-ride-selector-link @(Model.SelectedStatus == "rejected" ? "is-active" : string.Empty)"
       asp-controller="Rezervacija" asp-action="Index" asp-route-view="@Model.SelectedView" asp-route-status="rejected">Odbijene <span class="ss-selector-count">@Model.RejectedCount</span></a>
    <a class="ss-ride-selector-link @(Model.SelectedStatus == "completed" ? "is-active" : string.Empty)"
       asp-controller="Rezervacija" asp-action="Index" asp-route-view="@Model.SelectedView" asp-route-status="completed">Završene <span class="ss-selector-count">@Model.CompletedCount</span></a>
</nav>
