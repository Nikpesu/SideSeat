@model SideSeat.Models.Rezervacija
@using SideSeat.Models.ViewModels
@{
	ViewData["Title"] = "Detalji rezervacije";
	var currentUserId = int.TryParse(User.FindFirst(SideSeat.Security.SideSeatClaimTypes.KorisnikId)?.Value, out var idValue) ? idValue : 0;
	var canConfirm = User.IsInRole("Admin") || Model.Voznja?.VozacId == currentUserId;
	var isPassenger = Model.PutnikId == currentUserId;
	var isAdmin = User.IsInRole("Admin");
	var canCheckIn = isPassenger
		&& Model.Status == SideSeat.Models.StatusRezervacije.Potvrdena
		&& Model.Voznja?.Status is SideSeat.Models.StatusVoznje.Planirana or SideSeat.Models.StatusVoznje.Aktivna
		&& DateTime.Now >= Model.Voznja.Polazak.AddMinutes(-30);
	var statusClass = Model.Status == SideSeat.Models.StatusRezervacije.Potvrdena
		|| Model.Status == SideSeat.Models.StatusRezervacije.Zavrsena
		? "is-ok"
		: Model.Status == SideSeat.Models.StatusRezervacije.UProcesuPotvrde
			? "is-alert"
			: "is-off";
	var routeMap = new RouteMapViewModel
	{
		StartName = Model.Voznja?.PolazniGrad?.Naziv ?? string.Empty,
		StartLatitude = Model.Voznja?.PolazniGrad?.Latitude,
		StartLongitude = Model.Voznja?.PolazniGrad?.Longitude,
		EndName = Model.Voznja?.OdredisniGrad?.Naziv ?? string.Empty,
		EndLatitude = Model.Voznja?.OdredisniGrad?.Latitude,
		EndLongitude = Model.Voznja?.OdredisniGrad?.Longitude,
		Title = $"Ruta rezervacije #{Model.Id}",
		CssClass = "ss-detail-route-map"
	};
}

<section class="ss-page">
	<nav class="ss-breadcrumb" aria-label="Breadcrumb">
		<a asp-controller="Home" asp-action="Index">Dashboard</a>
		<span class="ss-breadcrumb-sep">/</span>
		<a asp-controller="Rezervacija" asp-action="Index">Rezervacije</a>
		<span class="ss-breadcrumb-sep">/</span>
		<span class="current" aria-current="page">Rezervacija #@Model.Id</span>
	</nav>

	<div class="ss-page-head">
		<h1>Detalji rezervacije</h1>
		<p>Podaci o rezervaciji, putniku i pripadajucoj voznji.</p>
	</div>

	<div class="ss-detail-card">
		@if (TempData["ReservationStatus"] is string reservationStatus)
		{
			<div class="alert alert-info" role="status">@reservationStatus</div>
		}
		<partial name="_RouteMap" model="routeMap" />

		<div class="ss-workflow-steps" aria-label="Koraci rezervacije">
			<span class="is-done">1. Rezervirano</span>
			<span class="@(Model.Status == SideSeat.Models.StatusRezervacije.UProcesuPotvrde ? "is-current" : "is-done")">2. Potvrda vozača</span>
			<span class="@(Model.CheckInAtUtc.HasValue ? "is-done" : canCheckIn ? "is-current" : "")">3. U autu</span>
			<span class="@(Model.Voznja?.Status == SideSeat.Models.StatusVoznje.Aktivna ? "is-current" : "")">4. Vožnja aktivna</span>
			<span class="@(Model.Status == SideSeat.Models.StatusRezervacije.Zavrsena ? "is-done" : "")">5. Ocjena i plaćanje</span>
		</div>

		<dl class="ss-detail-grid">
			<div>
				<dt>ID</dt>
				<dd>@Model.Id</dd>
			</div>
			<div>
				<dt>Status</dt>
				<dd><span class="ss-badge @statusClass">@Model.Status.ToDisplayName()</span></dd>
			</div>
			<div>
				<dt>Putnik</dt>
				<dd>@Model.Putnik?.Ime @Model.Putnik?.Prezime</dd>
			</div>
			<div>
				<dt>Voznja</dt>
				<dd>
					<a asp-controller="Voznja" asp-action="Details" asp-route-id="@Model.VoznjaId">
						Vožnja #@Model.VoznjaId:
						@Model.Voznja?.PolazniGrad?.Naziv -> @Model.Voznja?.OdredisniGrad?.Naziv
					</a>
				</dd>
			</div>
			<div>
				<dt>Broj mjesta</dt>
				<dd>@Model.BrojMjesta</dd>
			</div>
			<div>
				<dt>Ukupna cijena</dt>
				<dd>
					@Model.CijenaUkupno.ToString("0.00") EUR
					@if (Model.Napojnica > 0)
					{
						<span class="ss-muted d-block">Napojnica dana karticom pri ocjeni: @Model.Napojnica.ToString("0.00") EUR</span>
					}
				</dd>
			</div>
			<div>
				<dt>Način plaćanja</dt>
				<dd>@Model.NacinPlacanja</dd>
			</div>
			<div>
				<dt>Check-in</dt>
				<dd>@(Model.CheckInAtUtc.HasValue ? Model.CheckInAtUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "Nije potvrđeno")</dd>
			</div>
			<div>
				<dt>Vrijeme rezervacije</dt>
				<dd>@Model.VrijemeRezervacije.ToString("dd.MM.yyyy HH:mm")</dd>
			</div>
			<div>
				<dt>Napomena</dt>
				<dd>@(string.IsNullOrWhiteSpace(Model.Napomena) ? "Nema napomene." : Model.Napomena)</dd>
			</div>
		</dl>

		@if (isPassenger && Model.Status != SideSeat.Models.StatusRezervacije.Zavrsena)
		{
			<section class="ss-inline-panel">
				<h2 class="h5">Plaćanje</h2>
				<p class="ss-muted">Napojnica se dodaje nakon završene vožnje, u formi za ocjenu vozača i isključivo karticom.</p>
				<form asp-action="Payment" method="post" class="ss-inline-form">
					@Html.AntiForgeryToken()
					<input type="hidden" name="id" value="@Model.Id" />
					<label>
						<span>Način plaćanja</span>
						<select name="nacinPlacanja" class="form-select">
							<option value="@SideSeat.Models.NacinPlacanja.SideSeatSaldo" selected="@(Model.NacinPlacanja == SideSeat.Models.NacinPlacanja.SideSeatSaldo)">SideSeat saldo</option>
							<option value="@SideSeat.Models.NacinPlacanja.Gotovina" selected="@(Model.NacinPlacanja == SideSeat.Models.NacinPlacanja.Gotovina)">Gotovina vozaču</option>
						</select>
					</label>
					<button type="submit" class="ss-btn">Spremi plaćanje</button>
				</form>
			</section>
		}

		@if (canCheckIn && Model.CheckInAtUtc is null)
		{
			<form asp-action="CheckIn" method="post" class="ss-inline-panel" data-ss-checkin-form>
				@Html.AntiForgeryToken()
				<input type="hidden" name="id" value="@Model.Id" />
				<input type="hidden" name="latitude" data-checkin-lat />
				<input type="hidden" name="longitude" data-checkin-lng />
				<h2 class="h5">Potvrdi da si u autu</h2>
				<p>Lokacija se šalje samo ako je dopustiš u pregledniku i vidljiva je vozaču ove vožnje.</p>
				<div class="ss-checkin-map" data-checkin-map data-map-lat="@(Model.Voznja?.PolazniGrad?.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture))" data-map-lng="@(Model.Voznja?.PolazniGrad?.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture))" hidden></div>
					<p class="ss-checkin-status" data-checkin-status aria-live="polite">Lokacija još nije pronađena.</p>
					<div class="ss-checkin-actions">
						<button type="button" class="ss-btn ss-btn-secondary" data-checkin-map-toggle>Označi na karti</button>
							<button type="button" class="ss-btn ss-btn-secondary" data-checkin-locate>Pronađi lokaciju</button>
						<button type="submit" class="ss-btn">Pošalji lokaciju</button>
					</div>
			</form>
		}

		<div class="ss-actions">
			@if (canConfirm && Model.Status == SideSeat.Models.StatusRezervacije.UProcesuPotvrde)
			{
				<form asp-action="Confirm" method="post">
					@Html.AntiForgeryToken()
					<input type="hidden" name="id" value="@Model.Id" />
					<button type="submit" class="ss-btn">Potvrdi rezervaciju</button>
				</form>
				<form asp-action="Reject" method="post">
					@Html.AntiForgeryToken()
					<input type="hidden" name="id" value="@Model.Id" />
					<button type="submit" class="ss-btn ss-btn-secondary">Odbij rezervaciju</button>
				</form>
			}
			@if (isAdmin)
			{
				<a class="ss-btn" asp-action="AdminEdit" asp-route-id="@Model.Id">Uredi rezervaciju</a>
				<a class="ss-btn ss-btn-secondary" asp-action="AdminDelete" asp-route-id="@Model.Id">Obrisi rezervaciju</a>
			}
			<a class="ss-btn ss-btn-secondary" asp-controller="Rezervacija" asp-action="Index">Natrag na rezervacije</a>
			<a class="ss-btn" asp-controller="Home" asp-action="Index">Dashboard</a>
		</div>
	</div>
</section>
