@model SideSeat.Models.ViewModels.RezervacijaListViewModel
@using SideSeat.Models.ViewModels
@using System.Globalization
@{
    ViewData["Title"] = Model.Title;
    var search = ViewBag.Search as string ?? string.Empty;
    var selectedDate = ViewBag.Date as DateTime?;
    var dateFilter = new DateTimeInputViewModel
    {
        Name = "date",
        Label = "Datum",
        Value = selectedDate,
        DateOnly = true
    };
    var isAdmin = Model.IsAdmin;
}

<section class="ss-page" data-ss-list-page>
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Rezervacije</span>
    </nav>

    <partial name="_ReservationViewSelector" model="Model" />

    <div class="ss-page-head">
        <h1>@Model.Title</h1>
        <p>@Model.Description</p>
        <div class="ss-list-toolbar">
            <div class="ss-list-search">
                <label class="form-label" for="rezervacije-search">Pretraga</label>
                <input id="rezervacije-search" class="form-control" type="search" value="@search" placeholder="Putnik, ruta, status ili ID" data-ss-list-search />
            </div>
            <div class="ss-list-pagesize">
                <label class="form-label" for="rezervacije-pagesize">Prikaži</label>
                @{ var _ps = ViewBag.PageSize as int?; }
                <select id="rezervacije-pagesize" class="form-select" data-ss-list-pagesize>
                    @if (_ps == 10) { <text><option value="10" selected>10</option></text> } else { <text><option value="10">10</option></text> }
                    @if (_ps == null || _ps == 25) { <text><option value="25" selected>25</option></text> } else { <text><option value="25">25</option></text> }
                    @if (_ps == 50) { <text><option value="50" selected>50</option></text> } else { <text><option value="50">50</option></text> }
                    @if (_ps == 100) { <text><option value="100" selected>100</option></text> } else { <text><option value="100">100</option></text> }
                    @if (_ps == 0) { <text><option value="0" selected>∞</option></text> } else { <text><option value="0">∞</option></text> }
                </select>
            </div>
            <div class="ss-list-date">
                <partial name="_DateTimeInput" model="dateFilter" />
            </div>
        </div>
        <div class="ss-actions">
            @if (isAdmin)
            {
                <a class="ss-btn" asp-action="AdminCreate">Nova rezervacija</a>
            }
            <a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Active">Rezerviraj voznju</a>
        </div>
    </div>

    @if (Model.Rezervacije.Count == 0)
    {
        <p class="ss-empty">@Model.EmptyMessage</p>
    }
    else
    {
        <div class="ss-table-shell" role="region" aria-label="Lista rezervacija" tabindex="0" data-ss-list-content data-ss-keep-table>
            <table class="ss-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Putnik</th>
                        <th>Voznja</th>
                        <th>Mjesta</th>
                        <th>Cijena</th>
                        <th>Vrijeme rezervacije</th>
                        <th>Status</th>
                        <th>Akcija</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Rezervacije)
                    {
                        var rezervacija = item.Rezervacija;
                        var statusClass = rezervacija.Status == SideSeat.Models.StatusRezervacije.Potvrdena
                            || rezervacija.Status == SideSeat.Models.StatusRezervacije.Zavrsena
                            ? "is-ok"
                            : rezervacija.Status == SideSeat.Models.StatusRezervacije.UProcesuPotvrde
                                ? "is-alert"
                                : "is-off";

                        <tr tabindex="0"
                            data-ss-route-preview-source
                            data-route-start-name="@rezervacija.Voznja?.PolazniGrad?.Naziv"
                            data-route-start-lat="@(rezervacija.Voznja?.PolazniGrad?.Latitude?.ToString(CultureInfo.InvariantCulture))"
                            data-route-start-lng="@(rezervacija.Voznja?.PolazniGrad?.Longitude?.ToString(CultureInfo.InvariantCulture))"
                            data-route-end-name="@rezervacija.Voznja?.OdredisniGrad?.Naziv"
                            data-route-end-lat="@(rezervacija.Voznja?.OdredisniGrad?.Latitude?.ToString(CultureInfo.InvariantCulture))"
                            data-route-end-lng="@(rezervacija.Voznja?.OdredisniGrad?.Longitude?.ToString(CultureInfo.InvariantCulture))">
                            <td>@rezervacija.Id</td>
                            <td>@rezervacija.Putnik?.Ime @rezervacija.Putnik?.Prezime</td>
                            <td>
                                <a asp-controller="Voznja" asp-action="Details" asp-route-id="@rezervacija.VoznjaId">
                                    Vožnja #@rezervacija.VoznjaId:
                                    @rezervacija.Voznja?.PolazniGrad?.Naziv -> @rezervacija.Voznja?.OdredisniGrad?.Naziv
                                </a>
                            </td>
                            <td>@rezervacija.BrojMjesta</td>
                            <td>@rezervacija.CijenaUkupno.ToString("0.00") EUR</td>
                            <td>@rezervacija.VrijemeRezervacije.ToString("dd.MM.yyyy HH:mm")</td>
                            <td><span class="ss-badge @statusClass">@rezervacija.Status.ToDisplayName()</span></td>
                            <td>
                                <button type="button"
                                        class="ss-btn ss-btn-secondary ss-route-preview-button"
                                        data-ss-route-preview-button>Prikaži rutu</button>
                                <a class="ss-btn" asp-controller="Rezervacija" asp-action="Details" asp-route-id="@rezervacija.Id">Detalji</a>
                                @if (item.CanRate)
                                {
                                    <a class="ss-btn ss-btn-secondary" asp-controller="Ocjena" asp-action="Create" asp-route-rezervacijaId="@rezervacija.Id">@item.RateTargetLabel</a>
                                }
                                else if (item.HasRated)
                                {
                                    <span class="ss-badge is-ok">Ocijenjeno</span>
                                }
                                @if (isAdmin)
                                {
                                    <a class="ss-btn ss-btn-secondary" asp-action="AdminEdit" asp-route-id="@rezervacija.Id">Uredi</a>
                                    <a class="ss-btn ss-btn-secondary" asp-action="AdminDelete" asp-route-id="@rezervacija.Id">Obrisi</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
