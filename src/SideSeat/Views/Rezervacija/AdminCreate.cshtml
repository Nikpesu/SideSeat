@model SideSeat.Models.ViewModels.RezervacijaAdminFormViewModel
@{
    ViewData["Title"] = "Nova rezervacija";
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <a asp-controller="Rezervacija" asp-action="Index">Rezervacije</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Nova rezervacija</span>
    </nav>

    <div class="ss-page-head">
        <h1>Nova rezervacija</h1>
        <p>Unesite podatke za rezervaciju i automatski izracun cijene.</p>
    </div>

    <form asp-action="AdminCreate" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <partial name="_AdminForm" model="Model" />

        <div class="ss-actions">
            <button type="submit" class="ss-btn">Spremi</button>
            <a class="ss-btn ss-btn-secondary" asp-action="Index">Odustani</a>
        </div>
    </form>
</section>
