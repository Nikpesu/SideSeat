@model SideSeat.Models.Rezervacija
@{
    ViewData["Title"] = "Brisanje rezervacije";
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <a asp-controller="Rezervacija" asp-action="Index">Rezervacije</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Brisanje</span>
    </nav>

    <div class="ss-page-head">
        <h1>Brisanje rezervacije</h1>
        <p>Provjerite detalje prije uklanjanja rezervacije.</p>
    </div>

    <div class="ss-detail-card">
        <dl class="ss-detail-grid">
            <div>
                <dt>Putnik</dt>
                <dd>@Model.Putnik?.Ime @Model.Putnik?.Prezime</dd>
            </div>
            <div>
                <dt>Voznja</dt>
                <dd>@Model.Voznja?.PolazniGrad?.Naziv -> @Model.Voznja?.OdredisniGrad?.Naziv</dd>
            </div>
            <div>
                <dt>Broj mjesta</dt>
                <dd>@Model.BrojMjesta</dd>
            </div>
            <div>
                <dt>Status</dt>
                <dd>@Model.Status</dd>
            </div>
        </dl>

        <form asp-action="AdminDelete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="ss-actions">
                <button type="submit" class="ss-btn">Obrisi</button>
                <a class="ss-btn ss-btn-secondary" asp-action="Details" asp-route-id="@Model.Id">Odustani</a>
            </div>
        </form>
    </div>
</section>
