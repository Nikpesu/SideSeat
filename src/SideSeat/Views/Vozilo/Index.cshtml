@model IReadOnlyList<SideSeat.Models.Vozilo>
@{
    ViewData["Title"] = "Vozila";
    var search = ViewBag.Search as string ?? string.Empty;
}

<section class="ss-page" data-ss-list-page>
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Vozila</span>
    </nav>

    <div class="ss-page-head">
        <h1>Vozila</h1>
        <p>Pregled vozila koja su povezana s korisnicima vozacima.</p>
        <div class="ss-list-toolbar">
            <div class="ss-list-search">
                <label class="form-label" for="vozila-search">Pretraga</label>
                <input id="vozila-search" class="form-control" type="search" value="@search" placeholder="Marka, model, registracija ili vlasnik" data-ss-list-search />
            </div>
            <div class="ss-list-pagesize">
                <label class="form-label" for="vozilo-pagesize">Prikaži</label>
                @{ var _ps = ViewBag.PageSize as int?; }
                <select id="vozilo-pagesize" class="form-select" data-ss-list-pagesize>
                    @if (_ps == 10) { <text><option value="10" selected>10</option></text> } else { <text><option value="10">10</option></text> }
                    @if (_ps == null || _ps == 25) { <text><option value="25" selected>25</option></text> } else { <text><option value="25">25</option></text> }
                    @if (_ps == 50) { <text><option value="50" selected>50</option></text> } else { <text><option value="50">50</option></text> }
                    @if (_ps == 100) { <text><option value="100" selected>100</option></text> } else { <text><option value="100">100</option></text> }
                    @if (_ps == 0) { <text><option value="0" selected>∞</option></text> } else { <text><option value="0">∞</option></text> }
                </select>
            </div>
            <div class="ss-actions">
                <a class="ss-btn" asp-action="Create">Novo vozilo</a>
            </div>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <p class="ss-empty">Nema unesenih vozila.</p>
    }
    else
    {
        <div class="ss-table-shell" role="region" aria-label="Lista vozila" tabindex="0" data-ss-list-content>
            <table class="ss-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Marka</th>
                        <th>Model</th>
                        <th>Registracija</th>
                        <th>Godina</th>
                        <th>Sjedala</th>
                        <th>Vlasnik</th>
                        <th>Akcija</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vozilo in Model)
                    {
                        <tr>
                            <td>@vozilo.Id</td>
                            <td>@vozilo.Marka</td>
                            <td>@vozilo.Model</td>
                            <td>@vozilo.Registracija</td>
                            <td>@vozilo.GodinaProizvodnje</td>
                            <td>@vozilo.BrojSjedala</td>
                            <td>@(vozilo.Vlasnik is null ? "Nije dodijeljen" : $"{vozilo.Vlasnik.Ime} {vozilo.Vlasnik.Prezime}")</td>
                            <td>
                                <a class="ss-btn" asp-controller="Vozilo" asp-action="Details" asp-route-id="@vozilo.Id">Detalji</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
