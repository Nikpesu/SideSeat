@model SideSeat.Models.Vozilo
@{
    ViewData["Title"] = "Brisanje vozila";
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <a asp-controller="Vozilo" asp-action="Index">Vozila</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Brisanje</span>
    </nav>

    <div class="ss-page-head">
        <h1>Brisanje vozila</h1>
        <p>Provjerite podatke prije uklanjanja vozila iz sustava.</p>
    </div>

    <div class="ss-detail-card">
        <dl class="ss-detail-grid">
            <div>
                <dt>Marka i model</dt>
                <dd>@Model.Marka @Model.Model</dd>
            </div>
            <div>
                <dt>Registracija</dt>
                <dd>@Model.Registracija</dd>
            </div>
            <div>
                <dt>Godina proizvodnje</dt>
                <dd>@Model.GodinaProizvodnje</dd>
            </div>
            <div>
                <dt>Vlasnik</dt>
                <dd>@(Model.Vlasnik is null ? "Nije dodijeljen" : $"{Model.Vlasnik.Ime} {Model.Vlasnik.Prezime}")</dd>
            </div>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="ss-actions">
                <button type="submit" class="ss-btn">Obrisi</button>
                <a class="ss-btn ss-btn-secondary" asp-action="Details" asp-route-id="@Model.Id">Odustani</a>
            </div>
        </form>
    </div>
</section>
