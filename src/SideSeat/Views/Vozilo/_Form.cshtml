@model SideSeat.Models.Vozilo

@{
    var ownerLookup = new AutocompleteLookupViewModel
    {
        Name = nameof(Model.VlasnikId),
        Label = "Vlasnik",
        Endpoint = Url.Action("SearchDrivers", "Voznja") ?? string.Empty,
        SelectedId = Model.VlasnikId?.ToString() ?? string.Empty,
        SelectedText = Model.Vlasnik is null ? string.Empty : $"{Model.Vlasnik.Ime} {Model.Vlasnik.Prezime}",
        Placeholder = "Pretrazi vlasnika...",
        HelpText = "Odaberite korisnika kojem pripada vozilo.",
        MinimumLength = 0,
        Required = false
    };
}

<div class="ss-detail-card">
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Marka" class="form-label"></label>
            <input asp-for="Marka" class="form-control" />
            <span asp-validation-for="Marka" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Model" class="form-label"></label>
            <input asp-for="Model" class="form-control" />
            <span asp-validation-for="Model" class="text-danger"></span>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-md-6">
            <label asp-for="Registracija" class="form-label"></label>
            <input asp-for="Registracija" class="form-control" />
            <span asp-validation-for="Registracija" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="GodinaProizvodnje" class="form-label"></label>
            <input asp-for="GodinaProizvodnje" class="form-control" type="number" />
            <span asp-validation-for="GodinaProizvodnje" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="BrojSjedala" class="form-label"></label>
            <input asp-for="BrojSjedala" class="form-control" type="number" />
            <span asp-validation-for="BrojSjedala" class="text-danger"></span>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-md-4">
            <label asp-for="Boja" class="form-label"></label>
            <input asp-for="Boja" class="form-control" />
            <span asp-validation-for="Boja" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="ProsjecnaPotrosnja" class="form-label"></label>
            <input asp-for="ProsjecnaPotrosnja" class="form-control" type="number" step="0.1" />
            <span asp-validation-for="ProsjecnaPotrosnja" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <partial name="_AutocompleteLookup" model="ownerLookup" />
            <span asp-validation-for="VlasnikId" class="text-danger"></span>
        </div>
    </div>
</div>
