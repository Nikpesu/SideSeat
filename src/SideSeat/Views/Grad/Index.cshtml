@model IReadOnlyList<SideSeat.Models.Grad>
@{
	ViewData["Title"] = "Gradovi";
	var search = ViewBag.Search as string ?? string.Empty;
}

<section class="ss-page" data-ss-list-page>
	<nav class="ss-breadcrumb" aria-label="Breadcrumb">
		<a asp-controller="Home" asp-action="Index">Dashboard</a>
		<span class="ss-breadcrumb-sep">/</span>
		<span class="current" aria-current="page">Gradovi</span>
	</nav>

	<div class="ss-page-head">
		<h1>Gradovi</h1>
		<p>Popis gradova dostupnih u demo podacima.</p>
		<div class="ss-list-toolbar">
			<div class="ss-list-search">
				<label class="form-label" for="grad-search">Pretraga</label>
				<input id="grad-search" class="form-control" type="search" value="@search" placeholder="Naziv, drzava ili postanski broj" data-ss-list-search />
			</div>
			<div class="ss-list-pagesize">
				<label class="form-label" for="grad-pagesize">Prikaži</label>
				@{ var _ps = ViewBag.PageSize as int?; }
				<select id="grad-pagesize" class="form-select" data-ss-list-pagesize>
					@if (_ps == 10) { <text><option value="10" selected>10</option></text> } else { <text><option value="10">10</option></text> }
					@if (_ps == null || _ps == 25) { <text><option value="25" selected>25</option></text> } else { <text><option value="25">25</option></text> }
					@if (_ps == 50) { <text><option value="50" selected>50</option></text> } else { <text><option value="50">50</option></text> }
					@if (_ps == 100) { <text><option value="100" selected>100</option></text> } else { <text><option value="100">100</option></text> }
					@if (_ps == 0) { <text><option value="0" selected>∞</option></text> } else { <text><option value="0">∞</option></text> }
				</select>
			</div>
		</div>
		<div class="ss-actions">
			<a class="ss-btn" asp-action="Create">Novi grad</a>
		</div>
	</div>

	@if (Model.Count == 0)
	{
		<p class="ss-empty">Nema unesenih gradova.</p>
	}
	else
	{
		<div class="ss-table-shell" role="region" aria-label="Lista gradova" tabindex="0" data-ss-list-content>
			<table class="ss-table">
				<thead>
					<tr>
						<th>ID</th>
						<th>Naziv</th>
						<th>Drzava</th>
						<th>Postanski broj</th>
						<th>Akcija</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var grad in Model)
					{
						<tr>
							<td>@grad.Id</td>
							<td>@grad.Naziv</td>
							<td>@grad.Drzava</td>
							<td>@grad.PostanskiBroj</td>
							<td>
								<a class="ss-btn" asp-controller="Grad" asp-action="Details" asp-route-id="@grad.Id">Detalji</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
</section>
