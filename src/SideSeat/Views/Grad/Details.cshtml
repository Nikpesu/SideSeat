@model SideSeat.Models.Grad
@{
	ViewData["Title"] = "Detalji grada";
}

<section class="ss-page">
	<nav class="ss-breadcrumb" aria-label="Breadcrumb">
		<a asp-controller="Home" asp-action="Index">Dashboard</a>
		<span class="ss-breadcrumb-sep">/</span>
		<a asp-controller="Grad" asp-action="Index">Gradovi</a>
		<span class="ss-breadcrumb-sep">/</span>
		<span class="current" aria-current="page">@Model.Naziv</span>
	</nav>

	<div class="ss-page-head">
		<h1>Detalji grada</h1>
		<p>Osnovne informacije o odabranom gradu.</p>
	</div>

	<div class="ss-detail-card">
		<dl class="ss-detail-grid">
			<div>
				<dt>ID</dt>
				<dd>@Model.Id</dd>
			</div>
			<div>
				<dt>Naziv</dt>
				<dd>@Model.Naziv</dd>
			</div>
			<div>
				<dt>Drzava</dt>
				<dd>@Model.Drzava</dd>
			</div>
			<div>
				<dt>Postanski broj</dt>
				<dd>@Model.PostanskiBroj</dd>
			</div>
		</dl>

		<div class="ss-actions">
			<a class="ss-btn ss-btn-secondary" asp-controller="Grad" asp-action="Index">Natrag na gradove</a>
			<a class="ss-btn" asp-controller="Home" asp-action="Index">Dashboard</a>
		</div>
	</div>
</section>
