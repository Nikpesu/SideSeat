@model SideSeat.Models.Grad

<div class="ss-detail-card">
    <div class="mb-3">
        <label asp-for="Naziv" class="form-label"></label>
        <input asp-for="Naziv" class="form-control" />
        <span asp-validation-for="Naziv" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Drzava" class="form-label"></label>
        <input asp-for="Drzava" class="form-control" />
        <span asp-validation-for="Drzava" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PostanskiBroj" class="form-label"></label>
        <input asp-for="PostanskiBroj" class="form-control" />
        <span asp-validation-for="PostanskiBroj" class="text-danger"></span>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Latitude" class="form-label">Geografska širina</label>
            <input asp-for="Latitude" class="form-control" type="number" step="0.000001" />
            <span asp-validation-for="Latitude" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Longitude" class="form-label">Geografska dužina</label>
            <input asp-for="Longitude" class="form-control" type="number" step="0.000001" />
            <span asp-validation-for="Longitude" class="text-danger"></span>
        </div>
        <div class="col-12">
            <p class="form-text mb-0">
                Ostavite obje koordinate praznima za automatsko određivanje lokacije.
            </p>
        </div>
    </div>
</div>
