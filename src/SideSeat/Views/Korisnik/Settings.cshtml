@model SideSeat.Models.Auth.UserSettingsViewModel
@{
    ViewData["Title"] = "Postavke korisnika";
    var kycRequired = TempData["KycRequired"] as string;
    var settingsSaved = TempData["SettingsSaved"] as string;
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Postavke</span>
    </nav>

    <div class="ss-page-head">
        <h1>Postavke korisnika</h1>
        <p>Upravljaj adresom i statusom vozac/putnik.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(kycRequired))
    {
        <div class="alert alert-warning" role="alert">@kycRequired</div>
    }
    @if (!string.IsNullOrWhiteSpace(settingsSaved))
    {
        <div class="alert alert-success" role="alert">@settingsSaved</div>
    }

    <form asp-action="Settings" method="post" class="ss-detail-card">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Address" class="form-label"></label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PhoneNumber" class="form-label"></label>
            <input asp-for="PhoneNumber" class="form-control" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>

        <div class="form-check mb-2">
            <input asp-for="IsRider" class="form-check-input" disabled="@(!Model.CanDisableRider ? "disabled" : null)" />
            <label asp-for="IsRider" class="form-check-label"></label>
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsDriver" class="form-check-input" disabled="@(!Model.CanDisableDriver ? "disabled" : null)" />
            <label asp-for="IsDriver" class="form-check-label"></label>
        </div>
        @if (!Model.CanDisableRider || !Model.CanDisableDriver)
        {
            <small class="ss-datetime-help d-block mb-3">Aktivirane uloge su zakljucane i ne mogu se ugasiti kroz postavke.</small>
        }

        <div class="mb-3">
            <span class="ss-badge @(Model.KycPodnesen ? "is-ok" : "is-alert")">
                KYC: @(Model.KycPodnesen ? "ispunjen" : "nije ispunjen")
            </span>
            @if (!Model.KycPodnesen)
            {
                <a class="ss-btn ss-btn-secondary ms-2" asp-action="Kyc">Ispuni KYC</a>
            }
        </div>

        <hr />
        <h2 class="h5 mb-3">Promjena lozinke</h2>
        <div class="mb-3">
            <label asp-for="CurrentPassword" class="form-label"></label>
            <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label"></label>
            <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="ConfirmNewPassword" class="form-label"></label>
            <input asp-for="ConfirmNewPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
        </div>

        <div class="ss-actions">
            <button type="submit" class="ss-btn">Spremi postavke</button>
            <a class="ss-btn ss-btn-secondary" asp-controller="Home" asp-action="Index">Odustani</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
