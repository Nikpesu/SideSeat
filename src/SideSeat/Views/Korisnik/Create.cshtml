@model SideSeat.Models.ViewModels.KorisnikFormViewModel
@{
    ViewData["Title"] = "Novi korisnik";
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <a asp-controller="Korisnik" asp-action="Index">Korisnici</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Novi korisnik</span>
    </nav>

    <div class="ss-page-head">
        <h1>Novi korisnik</h1>
        <p>Unesite osnovne informacije i pristupne podatke za korisnika.</p>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <partial name="_Form" model="Model" />

        <div class="ss-actions">
            <button type="submit" class="ss-btn">Spremi</button>
            <a class="ss-btn ss-btn-secondary" asp-action="Index">Odustani</a>
        </div>
    </form>
</section>
