@model SideSeat.Models.ViewModels.KorisnikProfileViewModel
@{
    ViewData["Title"] = "Detalji korisnika";
    var isAdmin = User.IsInRole("Admin");
    var profileImage = string.IsNullOrWhiteSpace(Model.User.ProfilnaSlikaPath)
        ? Url.Content("~/images/profile-placeholder.svg")
        : Model.User.ProfilnaSlikaPath;
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <a asp-controller="Korisnik" asp-action="Index">Korisnici</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">@Model.User.Ime @Model.User.Prezime</span>
    </nav>

    <div class="ss-page-head">
        <img class="ss-profile-avatar" src="@profileImage" alt="Profilna slika korisnika @Model.User.Ime @Model.User.Prezime" />
        <h1>Detalji korisnika</h1>
        <p>@(Model.CanViewFullDetails ? "Profil, status i povezani podaci korisnika." : "Osnovni kontakt podaci putnika.")</p>
    </div>

    <div class="ss-detail-card">
        <dl class="ss-detail-grid">
            <div>
                <dt>Ime i prezime</dt>
                <dd>@Model.User.Ime @Model.User.Prezime</dd>
            </div>
            <div>
                <dt>Broj mobitela</dt>
                <dd><a href="tel:@Model.User.BrojMobitela">@Model.User.BrojMobitela</a></dd>
            </div>
            @if (Model.CanViewFullDetails)
            {
                <div>
                    <dt>ID</dt>
                    <dd>@Model.User.Id</dd>
                </div>
                <div>
                    <dt>Tip korisnika</dt>
                    <dd>@Model.User.Tip</dd>
                </div>
                <div>
                    <dt>Status</dt>
                    <dd><span class="ss-badge @(Model.User.JeAktivan ? "is-ok" : "is-off")">@(Model.User.JeAktivan ? "Aktivan" : "Neaktivan")</span></dd>
                </div>
                <div>
                    <dt>Email</dt>
                    <dd>@Model.User.Email</dd>
                </div>
                <div>
                    <dt>Adresa</dt>
                    <dd>@Model.User.Adresa</dd>
                </div>
                <div>
                    <dt>Datum registracije</dt>
                    <dd>@Model.User.DatumRegistracije.ToString("dd.MM.yyyy")</dd>
                </div>
                <div>
                    <dt>Vozilo</dt>
                    <dd>@(Model.User.Vozilo is null ? "Nema povezano vozilo" : $"{Model.User.Vozilo.Marka} {Model.User.Vozilo.Model}")</dd>
                </div>
                <div>
                    <dt>KYC status</dt>
                    <dd>@(Model.User.KycPodnesen ? "Ispunjen" : "Nije ispunjen")</dd>
                </div>
                <div>
                    <dt>Kreirane voznje</dt>
                    <dd>@(Model.User.KreiraneVoznje?.Count ?? 0)</dd>
                </div>
                <div>
                    <dt>Rezervacije</dt>
                    <dd>@(Model.User.Rezervacije?.Count ?? 0)</dd>
                </div>
                <div>
                    <dt>Prosjecna ocjena</dt>
                    <dd>@(Model.BrojPrimljenihOcjena == 0 ? "Nema ocjena" : Model.ProsjecnaOcjena.ToString("0.0"))</dd>
                </div>
                <div>
                    <dt>Primljene ocjene</dt>
                    <dd>@Model.BrojPrimljenihOcjena</dd>
                </div>
            }
        </dl>

        <div class="ss-actions">
            @if (isAdmin)
            {
                <a class="ss-btn" asp-controller="Korisnik" asp-action="Edit" asp-route-id="@Model.User.Id">Uredi korisnika</a>
                <a class="ss-btn ss-btn-secondary" asp-controller="Korisnik" asp-action="Delete" asp-route-id="@Model.User.Id">Obrisi korisnika</a>
            }
            @if (Model.CanViewFullDetails)
            {
                <a class="ss-btn ss-btn-secondary" asp-controller="Korisnik" asp-action="Index">Natrag na korisnike</a>
            }
            <a class="ss-btn" asp-controller="Home" asp-action="Index">Dashboard</a>
        </div>
    </div>

    @if (Model.CanViewFullDetails)
    {
    <div class="ss-detail-card">
        <h2>Primljeni komentari</h2>
        @if (Model.PrimljeneOcjene.Count == 0)
        {
            <p class="ss-empty">Nema primljenih komentara.</p>
        }
        else
        {
            <div class="ss-detail-grid">
                @foreach (var ocjena in Model.PrimljeneOcjene)
                {
                    <div>
                        <dt>@ocjena.Autor (@ocjena.BrojZvjezdica/5)</dt>
                        <dd>
                            @ocjena.Komentar
                            @if (ocjena.Uredeno.HasValue)
                            {
                                <small class="d-block ss-datetime-help">Uređena recenzija</small>
                            }
                            <partial name="_OcjenaSlike" model="ocjena.Slike" />
                            @if (!string.IsNullOrWhiteSpace(ocjena.AdminFeedback))
                            {
                                <div class="alert alert-info mt-2 mb-0">
                                    <strong>Feedback administratora:</strong> @ocjena.AdminFeedback
                                    <small class="d-block ss-datetime-help">@ocjena.AdminFeedbackAuthor</small>
                                </div>
                            }
                        </dd>
                    </div>
                }
            </div>
        }
    </div>

    <div class="ss-detail-card">
        <h2>Dani komentari</h2>
        @if (Model.DaneOcjene.Count == 0)
        {
            <p class="ss-empty">Nema danih komentara.</p>
        }
        else
        {
            <div class="ss-detail-grid">
                @foreach (var ocjena in Model.DaneOcjene)
                {
                    <div>
                        <dt>@ocjena.Primatelj (@ocjena.BrojZvjezdica/5)</dt>
                        <dd>
                            @ocjena.Komentar
                            @if (ocjena.Uredeno.HasValue)
                            {
                                <small class="d-block ss-datetime-help">Uređena recenzija</small>
                            }
                            <partial name="_OcjenaSlike" model="ocjena.Slike" />
                            @if (!string.IsNullOrWhiteSpace(ocjena.AdminFeedback))
                            {
                                <div class="alert alert-info mt-2 mb-0">
                                    <strong>Feedback administratora:</strong> @ocjena.AdminFeedback
                                    <small class="d-block ss-datetime-help">@ocjena.AdminFeedbackAuthor</small>
                                </div>
                            }
                        </dd>
                    </div>
                }
            </div>
        }
    </div>
    }
</section>
