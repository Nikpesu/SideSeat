@model SideSeat.Models.Balance.SaldoViewModel
@{
    ViewData["Title"] = "Saldo";
    var saved = TempData["SaldoSaved"] as string;
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Saldo</span>
    </nav>

    <div class="ss-page-head">
        <h1>Saldo korisnika</h1>
        <p>Pregled stanja i uplata/isplata sredstava.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(saved))
    {
        <div class="alert alert-success" role="alert">@saved</div>
    }

    <div class="ss-detail-card mb-4">
        <h2 class="h5">Trenutno stanje</h2>
        <p class="mb-0"><strong>@Model.TrenutniSaldo.ToString("0.00") EUR</strong></p>
    </div>

    <form asp-action="Saldo" method="post" class="ss-detail-card">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Akcija" class="form-label"></label>
            <select asp-for="Akcija" class="form-select">
                <option value="uplata">Uplata</option>
                <option value="isplata">Isplata</option>
            </select>
            <span asp-validation-for="Akcija" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Iznos" class="form-label"></label>
            <input asp-for="Iznos" class="form-control" type="number" step="0.01" min="0.01" />
            <span asp-validation-for="Iznos" class="text-danger"></span>
        </div>

        <div class="ss-actions">
            <button type="submit" class="ss-btn">Potvrdi</button>
            <a class="ss-btn ss-btn-secondary" asp-controller="Home" asp-action="Index">Natrag</a>
        </div>
    </form>

    <div class="ss-detail-card mt-4">
        <h2 class="h5">Povijest transakcija</h2>
        @if (Model.Transakcije.Count == 0)
        {
            <p class="ss-empty">Jos nema zabiljezenih transakcija.</p>
        }
        else
        {
            <div class="ss-table-shell" role="region" aria-label="Povijest transakcija" tabindex="0">
                <table class="ss-table">
                    <thead>
                        <tr>
                            <th>Vrijeme</th>
                            <th>Tip</th>
                            <th>Iznos</th>
                            <th>Saldo prije</th>
                            <th>Saldo poslije</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var tx in Model.Transakcije)
                    {
                        var isUplata = tx.Tip.Equals("uplata", StringComparison.OrdinalIgnoreCase);
                        <tr>
                            <td>@tx.Vrijeme.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(isUplata ? "Uplata" : "Isplata")</td>
                            <td>@(isUplata ? "+" : "-")@tx.Iznos.ToString("0.00") EUR</td>
                            <td>@tx.SaldoPrije.ToString("0.00") EUR</td>
                            <td>@tx.SaldoPoslije.ToString("0.00") EUR</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
