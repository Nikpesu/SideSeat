@model SideSeat.Models.Forms.VoznjaFormViewModel

@{
    var driverLookup = new AutocompleteLookupViewModel
    {
        Name = nameof(Model.VozacId),
        Label = "Vozac",
        Endpoint = Url.Action("SearchDrivers", "Voznja") ?? string.Empty,
        SelectedId = Model.VozacId.ToString(),
        SelectedText = Model.Vozaci.FirstOrDefault(x => x.Value == Model.VozacId.ToString())?.Text ?? string.Empty,
        Placeholder = "Pretrazi vozaca...",
        HelpText = "Krenite tipkati ime ili prezime vozaca.",
        MinimumLength = 0,
        Required = true
    };

    var startCityLookup = new AutocompleteLookupViewModel
    {
        Name = nameof(Model.PolazniGradId),
        Label = "Polazni grad",
        Endpoint = Url.Action("SearchCities", "Voznja") ?? string.Empty,
        SelectedId = Model.PolazniGradId.ToString(),
        SelectedText = Model.Gradovi.FirstOrDefault(x => x.Value == Model.PolazniGradId.ToString())?.Text ?? string.Empty,
        Placeholder = "Pretrazi polazni grad...",
        HelpText = "Pretraga gradova radi asinkrono preko servera.",
        MinimumLength = 0,
        Required = true
    };

    var endCityLookup = new AutocompleteLookupViewModel
    {
        Name = nameof(Model.OdredisniGradId),
        Label = "Odredisni grad",
        Endpoint = Url.Action("SearchCities", "Voznja") ?? string.Empty,
        SelectedId = Model.OdredisniGradId.ToString(),
        SelectedText = Model.Gradovi.FirstOrDefault(x => x.Value == Model.OdredisniGradId.ToString())?.Text ?? string.Empty,
        Placeholder = "Pretrazi odredisni grad...",
        HelpText = "Autocompletion koristi AJAX i vraca samo relevantne gradove.",
        MinimumLength = 0,
        Required = true
    };

    var departureDate = new DateTimeInputViewModel
    {
        Name = nameof(Model.Polazak),
        Label = "Polazak",
        Value = Model.Polazak,
        HelpText = "Vrijeme dolaska se računa automatski iz trajanja rute.",
        Required = true
    };
}

<div class="ss-detail-card">
    @if (Model.CanSelectDriver)
    {
        <div class="mb-3">
            <partial name="_AutocompleteLookup" model="driverLookup" />
            <span asp-validation-for="VozacId" class="text-danger"></span>
        </div>
    }
    else
    {
        <input type="hidden" asp-for="VozacId" />
    }

    <div class="row g-3">
        <div class="col-md-6">
            <partial name="_AutocompleteLookup" model="startCityLookup" />
            <span asp-validation-for="PolazniGradId" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <partial name="_AutocompleteLookup" model="endCityLookup" />
            <span asp-validation-for="OdredisniGradId" class="text-danger"></span>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-md-6">
            <partial name="_DateTimeInput" model="departureDate" />
            <span asp-validation-for="Polazak" class="text-danger"></span>
        </div>
        <div class="col-md-6 d-flex align-items-end">
            <p class="ss-datetime-help mb-2">Očekivani dolazak izračunava se automatski iz rute pri spremanju.</p>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-md-4">
            <label asp-for="CijenaPoMjestu" class="form-label"></label>
            <input asp-for="CijenaPoMjestu" class="form-control" />
            <span asp-validation-for="CijenaPoMjestu" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="UkupnoMjesta" class="form-label"></label>
            <input asp-for="UkupnoMjesta" class="form-control" />
            <span asp-validation-for="UkupnoMjesta" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="SlobodnaMjesta" class="form-label"></label>
            <input asp-for="SlobodnaMjesta" class="form-control" />
            <span asp-validation-for="SlobodnaMjesta" class="text-danger"></span>
        </div>
    </div>

    @if (Model.CanSelectDriver)
    {
        <div class="row g-3 mt-1">
            <div class="col-md-6">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<SideSeat.Models.StatusVoznje>()"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
        </div>
    }
    else
    {
        <input type="hidden" asp-for="Status" />
    }

    <div class="mt-3">
        <label asp-for="Opis" class="form-label"></label>
        <textarea asp-for="Opis" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Opis" class="text-danger"></span>
    </div>
</div>
