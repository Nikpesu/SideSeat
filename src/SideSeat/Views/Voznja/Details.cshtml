@model SideSeat.Models.Rides.VoznjaDetailsViewModel
@using SideSeat.Models.ViewModels
@{
	ViewData["Title"] = "Detalji voznje";
	var currentUserId = int.TryParse(User.FindFirst(SideSeat.Security.SideSeatClaimTypes.KorisnikId)?.Value, out var idValue) ? idValue : 0;
	var voznja = Model.Voznja;
	var canEdit = User.IsInRole("Admin") || voznja.VozacId == currentUserId;
	var canStart = canEdit && voznja.Status == SideSeat.Models.StatusVoznje.Planirana && Model.AllConfirmedPassengersReady;
	var canFinish = canEdit && voznja.Status is SideSeat.Models.StatusVoznje.Planirana or SideSeat.Models.StatusVoznje.Aktivna;
	var canBook = !canEdit && voznja.Status == SideSeat.Models.StatusVoznje.Planirana && voznja.SlobodnaMjesta > 0;
	var statusClass = voznja.Status == SideSeat.Models.StatusVoznje.Planirana
		? "is-ok"
		: voznja.Status == SideSeat.Models.StatusVoznje.Zavrsena
			? "is-alert"
			: "is-off";
	var routeMap = new RouteMapViewModel
	{
		StartName = voznja.PolazniGrad?.Naziv ?? string.Empty,
		StartLatitude = voznja.PolazniGrad?.Latitude,
		StartLongitude = voznja.PolazniGrad?.Longitude,
		EndName = voznja.OdredisniGrad?.Naziv ?? string.Empty,
		EndLatitude = voznja.OdredisniGrad?.Latitude,
		EndLongitude = voznja.OdredisniGrad?.Longitude,
		Title = $"Ruta vožnje #{voznja.Id}",
		CssClass = "ss-detail-route-map"
	};
}

<section class="ss-page">
	<nav class="ss-breadcrumb" aria-label="Breadcrumb">
		<a asp-controller="Home" asp-action="Index">Dashboard</a>
		<span class="ss-breadcrumb-sep">/</span>
		<a asp-controller="Voznja" asp-action="Index">Voznje</a>
		<span class="ss-breadcrumb-sep">/</span>
		<span class="current" aria-current="page">Voznja #@voznja.Id</span>
	</nav>

	<div class="ss-page-head">
		<h1>Detalji voznje</h1>
		<p>Ruta, raspored, cijena i broj rezerviranih mjesta.</p>
	</div>

	<div class="ss-detail-card">
		@if (TempData["RideExecuted"] is string rideExecutedMessage)
		{
			<div class="alert alert-info" role="status">@rideExecutedMessage</div>
		}
		@if (TempData["ReservationStatus"] is string reservationStatusMessage)
		{
			<div class="alert alert-info" role="status">@reservationStatusMessage</div>
		}

		<partial name="_RouteMap" model="routeMap" />

		<div class="ss-workflow-steps" aria-label="Koraci vožnje">
			<span class="is-done">1. Izrada</span>
			<span class="@(Model.Putnici.Count > 0 ? "is-done" : "is-current")">2. Rezervacije</span>
			<span class="@(Model.AllConfirmedPassengersReady ? "is-done" : "is-current")">3. Putnici spremni</span>
			<span class="@(voznja.Status == SideSeat.Models.StatusVoznje.Aktivna ? "is-current" : voznja.Status == SideSeat.Models.StatusVoznje.Zavrsena ? "is-done" : "")">4. Aktivna</span>
			<span class="@(voznja.Status == SideSeat.Models.StatusVoznje.Zavrsena ? "is-done" : "")">5. Ocjena i naplata</span>
		</div>

		<dl class="ss-detail-grid">
			<div>
				<dt>ID</dt>
				<dd>@voznja.Id</dd>
			</div>
			<div>
				<dt>Status</dt>
				<dd><span class="ss-badge @statusClass">@voznja.Status</span></dd>
			</div>
			<div>
				<dt>Vozac</dt>
				<dd>@voznja.Vozac?.Ime @voznja.Vozac?.Prezime</dd>
			</div>
			<div>
				<dt>Ruta</dt>
				<dd>@voznja.PolazniGrad?.Naziv -> @voznja.OdredisniGrad?.Naziv</dd>
			</div>
			<div>
				<dt>Polazak</dt>
				<dd>@voznja.Polazak.ToString("dd.MM.yyyy HH:mm")</dd>
			</div>
			<div>
				<dt>Ocekivani dolazak</dt>
				<dd>@voznja.OcekivaniDolazak.ToString("dd.MM.yyyy HH:mm")</dd>
			</div>
			<div>
				<dt>Cijena po mjestu</dt>
				<dd>@voznja.CijenaPoMjestu.ToString("0.00") EUR</dd>
			</div>
			<div>
				<dt>Mjesta</dt>
				<dd>@voznja.SlobodnaMjesta slobodno od @voznja.UkupnoMjesta</dd>
			</div>
			<div>
				<dt>Broj rezervacija</dt>
				<dd>@Model.Putnici.Count</dd>
			</div>
			<div>
				<dt>Saldo za naplatu</dt>
				<dd>@Model.SaldoDue.ToString("0.00") EUR</dd>
			</div>
			<div>
				<dt>Gotovina za vozača</dt>
				<dd>@Model.CashDue.ToString("0.00") EUR</dd>
			</div>
			<div>
				<dt>Prosjek ocjena voznje</dt>
				<dd>@(Model.BrojOcjenaVoznje == 0 ? "Nema ocjena" : Model.ProsjecnaOcjenaVoznje.ToString("0.0"))</dd>
			</div>
			<div>
				<dt>Prosjek ocjena vozaca</dt>
				<dd>@(Model.BrojOcjenaVozaca == 0 ? "Nema ocjena" : Model.ProsjecnaOcjenaVozaca.ToString("0.0"))</dd>
			</div>
			<div>
				<dt>Opis</dt>
				<dd>@(string.IsNullOrWhiteSpace(voznja.Opis) ? "Bez dodatne napomene." : voznja.Opis)</dd>
			</div>
		</dl>

		<h2 class="h5 mt-4">Putnici na voznji</h2>
		@if (Model.Putnici.Count == 0)
		{
			<p class="ss-empty">Za ovu voznju jos nema rezervacija.</p>
		}
		else
		{
			<div class="ss-table-shell" role="region" aria-label="Putnici voznje" tabindex="0">
				<table class="ss-table">
					<thead>
						<tr>
							<th>Rezervacija</th>
							<th>Putnik</th>
							<th>Status</th>
							<th>Mjesta</th>
							<th>Plaćanje</th>
							<th>Spreman</th>
							<th>Kontakt</th>
							<th>Ocjena putnika</th>
							<th>Ocjena vozaca</th>
							@if (canEdit)
							{
								<th>Akcija</th>
							}
						</tr>
					</thead>
					<tbody>
					@foreach (var putnik in Model.Putnici)
					{
						<tr>
							<td>#@putnik.RezervacijaId</td>
							<td>
								<a asp-controller="Korisnik" asp-action="Details" asp-route-id="@putnik.PutnikId">@putnik.PutnikIme</a>
							</td>
							<td>@putnik.Status.ToDisplayName()</td>
							<td>@putnik.BrojMjesta</td>
							<td>
								@putnik.NacinPlacanja · @putnik.CijenaUkupno.ToString("0.00") EUR
								@if (putnik.Napojnica > 0)
								{
									<span class="ss-muted d-block">+ @putnik.Napojnica.ToString("0.00") EUR napojnica karticom</span>
								}
							</td>
							<td>@(putnik.CheckInAtUtc.HasValue ? "Da" : "Ne")</td>
							<td>
								@if (canEdit && !string.IsNullOrWhiteSpace(putnik.PutnikTelefon))
								{
									<a href="tel:@putnik.PutnikTelefon">@putnik.PutnikTelefon</a>
								}
								else
								{
									<span>-</span>
								}
							</td>
							<td>@(putnik.PutnikJeOcijenio ? "Da" : "Ne")</td>
							<td>@(putnik.VozacJeOcijenio ? "Da" : "Ne")</td>
							@if (canEdit)
							{
								<td>
									@if (putnik.Status == SideSeat.Models.StatusRezervacije.UProcesuPotvrde)
									{
										<div class="ss-actions">
											<form asp-controller="Rezervacija" asp-action="Confirm" method="post">
												@Html.AntiForgeryToken()
												<input type="hidden" name="id" value="@putnik.RezervacijaId" />
												<input type="hidden" name="returnUrl" value="/Voznja/Details/@voznja.Id" />
												<button type="submit" class="ss-btn">Potvrdi</button>
											</form>
											<form asp-controller="Rezervacija" asp-action="Reject" method="post">
												@Html.AntiForgeryToken()
												<input type="hidden" name="id" value="@putnik.RezervacijaId" />
												<input type="hidden" name="returnUrl" value="/Voznja/Details/@voznja.Id" />
												<button type="submit" class="ss-btn ss-btn-secondary">Odbij</button>
											</form>
										</div>
									}
									else
									{
										<a class="ss-btn ss-btn-secondary" asp-controller="Rezervacija" asp-action="Details" asp-route-id="@putnik.RezervacijaId">Detalji</a>
									}
								</td>
							}
						</tr>
					}
					</tbody>
				</table>
			</div>
		}

		<h2 class="h5 mt-4">Ocjene ove voznje</h2>
		@if (Model.OcjeneVoznje.Count == 0)
		{
			<p class="ss-empty">Za ovu voznju jos nema ocjena.</p>
		}
		else
		{
			<div class="ss-table-shell" role="region" aria-label="Ocjene voznje" tabindex="0">
				<table class="ss-table">
					<thead>
						<tr>
							<th>Ocjena</th>
							<th>Rezervacija</th>
							<th>Autor</th>
							<th>Primatelj</th>
							<th>Zvjezdice</th>
							<th>Komentar</th>
						</tr>
					</thead>
					<tbody>
					@foreach (var ocjena in Model.OcjeneVoznje)
					{
						<tr>
							<td>#@ocjena.OcjenaId</td>
							<td>#@ocjena.RezervacijaId</td>
							<td>@ocjena.AutorIme</td>
							<td>@ocjena.PrimateljIme</td>
							<td>@ocjena.BrojZvjezdica</td>
							<td>
								@ocjena.Komentar
								@if (ocjena.Uredeno.HasValue)
								{
									<small class="d-block ss-datetime-help">Uređena recenzija</small>
								}
								<partial name="_OcjenaSlike" model="ocjena.Slike" />
								@if (!string.IsNullOrWhiteSpace(ocjena.AdminFeedback))
								{
									<div class="alert alert-info mt-2 mb-0">
										<strong>Feedback administratora:</strong> @ocjena.AdminFeedback
										<small class="d-block ss-datetime-help">@ocjena.AdminFeedbackAuthor</small>
									</div>
								}
							</td>
						</tr>
					}
					</tbody>
				</table>
			</div>
		}

		<h2 class="h5 mt-4">Ocjene vozaca (@voznja.Vozac?.Ime @voznja.Vozac?.Prezime)</h2>
		@if (Model.OcjeneVozaca.Count == 0)
		{
			<p class="ss-empty">Vozac jos nema zaprimljenih ocjena.</p>
		}
		else
		{
			<div class="ss-table-shell" role="region" aria-label="Ocjene vozaca" tabindex="0">
				<table class="ss-table">
					<thead>
						<tr>
							<th>Ocjena</th>
							<th>Rezervacija</th>
							<th>Autor</th>
							<th>Zvjezdice</th>
							<th>Komentar</th>
						</tr>
					</thead>
					<tbody>
					@foreach (var ocjena in Model.OcjeneVozaca)
					{
						<tr>
							<td>#@ocjena.OcjenaId</td>
							<td>#@ocjena.RezervacijaId</td>
							<td>@ocjena.AutorIme</td>
							<td>@ocjena.BrojZvjezdica</td>
							<td>
								@ocjena.Komentar
								@if (ocjena.Uredeno.HasValue)
								{
									<small class="d-block ss-datetime-help">Uređena recenzija</small>
								}
								<partial name="_OcjenaSlike" model="ocjena.Slike" />
								@if (!string.IsNullOrWhiteSpace(ocjena.AdminFeedback))
								{
									<div class="alert alert-info mt-2 mb-0">
										<strong>Feedback administratora:</strong> @ocjena.AdminFeedback
										<small class="d-block ss-datetime-help">@ocjena.AdminFeedbackAuthor</small>
									</div>
								}
							</td>
						</tr>
					}
					</tbody>
				</table>
			</div>
		}

		<div class="ss-actions">
			@if (canBook)
			{
				<a class="ss-btn" asp-controller="Rezervacija" asp-action="Create" asp-route-voznjaId="@voznja.Id">Rezerviraj voznju</a>
			}
			@if (canEdit)
			{
				@if (voznja.Status != SideSeat.Models.StatusVoznje.Zavrsena && voznja.Status != SideSeat.Models.StatusVoznje.Otkazana)
				{
					<a class="ss-btn" asp-controller="Voznja" asp-action="Current">Trenutna vožnja</a>
					@if (canStart)
					{
						<form asp-controller="Voznja" asp-action="Start" method="post">
							@Html.AntiForgeryToken()
							<input type="hidden" name="id" value="@voznja.Id" />
							<button type="submit" class="ss-btn">Pokreni vožnju</button>
						</form>
					}
					<a class="ss-btn" asp-controller="Voznja" asp-action="Finish" asp-route-id="@voznja.Id">Završi i naplati</a>
				}
				<a class="ss-btn" asp-controller="Voznja" asp-action="Edit" asp-route-id="@voznja.Id">Uredi voznju</a>
				<a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Delete" asp-route-id="@voznja.Id">Obrisi voznju</a>
			}
			<a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Index">Natrag na voznje</a>
			<a class="ss-btn" asp-controller="Home" asp-action="Index">Dashboard</a>
		</div>
	</div>
</section>
