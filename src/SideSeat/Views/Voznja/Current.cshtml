@model SideSeat.Models.Rides.CurrentRideViewModel
@{
    ViewData["Title"] = "Trenutna vožnja";
}

<section class="ss-page ss-live-rides" data-ss-live-rides>
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Trenutna vožnja</span>
    </nav>

    <div class="ss-page-head">
        <h1>Trenutna vožnja</h1>
        <p>Vožnje u aktualnom prozoru, spremnost putnika, gotovina za naplatu, lokacija i chat.</p>
    </div>

    @if (TempData["RideExecuted"] is string status)
    {
        <div class="alert alert-info" role="status">@status</div>
    }

    @if (Model.Rides.Count == 0)
    {
        <article class="ss-detail-card">
            <p class="ss-empty">Trenutno nema vožnji za prikaz. Ovdje će se pojaviti vožnje blizu polaska ili aktivne vožnje.</p>
        </article>
    }
    else
    {
        <div class="ss-live-ride-stack">
            @foreach (var ride in Model.Rides)
            {
                <article class="ss-detail-card ss-live-ride-card"
                         data-ss-live-ride
                         data-ride-id="@ride.Voznja.Id">
                @if (ride.ViewerIsDriver)
                {
                    <header class="ss-live-ride-head">
                        <div>
                            <span class="ss-badge @(ride.AllReady ? "is-ok" : "is-alert")">
                                @(ride.AllReady ? "Svi spremni" : "Čeka putnike")
                            </span>
                            <h2>@ride.Voznja.PolazniGrad?.Naziv → @ride.Voznja.OdredisniGrad?.Naziv</h2>
                            <p>@ride.Voznja.Polazak.ToString("dd.MM.yyyy HH:mm") · @ride.Voznja.Status</p>
                        </div>
                        <div class="ss-live-ride-money">
                            <span>Gotovina za vozača</span>
                            <strong>@ride.CashDue.ToString("0.00") EUR</strong>
                        </div>
                    </header>

                    <div class="ss-workflow-steps" aria-label="Koraci vožnje">
                        <span class="is-done">1. Izrada <span class="ss-info" tabindex="0" role="note" aria-label="Objašnjenje koraka">i<span class="ss-info-pop">Vožnja je objavljena s polazištem, odredištem i vremenom polaska.</span></span></span>
                        <span class="is-done">2. Rezervacije <span class="ss-info" tabindex="0" role="note" aria-label="Objašnjenje koraka">i<span class="ss-info-pop">Putnici rezerviraju mjesta; vozač potvrđuje ili odbija rezervacije.</span></span></span>
                        <span class="@(ride.AllReady ? "is-done" : "is-current")">3. Putnici spremni <span class="ss-info" tabindex="0" role="note" aria-label="Objašnjenje koraka">i<span class="ss-info-pop">Svaki potvrđeni putnik radi check-in i šalje lokaciju — dostupno 30 min prije polaska do pokretanja vožnje.</span></span></span>
                        <span class="@(ride.Voznja.Status == SideSeat.Models.StatusVoznje.Aktivna ? "is-current" : "")">4. Aktivna <span class="ss-info" tabindex="0" role="note" aria-label="Objašnjenje koraka">i<span class="ss-info-pop">Vozač pokreće vožnju kad su svi spremni — moguće od 30 min prije polaska do 12 h nakon zakazanog termina.</span></span></span>
                        <span>5. Završetak <span class="ss-info" tabindex="0" role="note" aria-label="Objašnjenje koraka">i<span class="ss-info-pop">Vozač završava vožnju i naplaćuje gotovinu/saldo; zatim slijede ocjene.</span></span></span>
                    </div>

                    <div class="ss-live-grid">
                        <section>
                            <h3 class="h5">Putnici</h3>
                            <div class="ss-live-passengers">
                                @foreach (var passenger in ride.Putnici)
                                {
                                    <article class="ss-live-passenger"
                                             data-reservation-id="@passenger.RezervacijaId"
                                             data-passenger-id="@passenger.PutnikId">
                                        <div>
                                            <strong>@passenger.PutnikIme</strong>
                                            <span>@passenger.Status.ToDisplayName() · @passenger.BrojMjesta mjesta</span>
                                            <a href="tel:@passenger.PutnikTelefon">@passenger.PutnikTelefon</a>
                                            <a class="ss-link" asp-controller="Rezervacija" asp-action="Details" asp-route-id="@passenger.RezervacijaId">Otvori rezervaciju →</a>
                                        </div>
                                        <div class="ss-live-passenger-meta">
                                            <span class="ss-badge @(passenger.CheckInAtUtc.HasValue ? "is-ok" : "is-alert")" data-ready-state>
                                                @(passenger.CheckInAtUtc.HasValue ? "U autu" : "Čeka")
                                            </span>
                                            <span>@passenger.NacinPlacanja</span>
                                            <strong>@((passenger.CijenaUkupno + passenger.Napojnica).ToString("0.00")) EUR</strong>
                                        </div>
                                        @if (passenger.LastLatitude.HasValue && passenger.LastLongitude.HasValue)
                                        {
                                            <small data-location-state>
                                                Lokacija: @passenger.LastLatitude.Value.ToString("0.000000"), @passenger.LastLongitude.Value.ToString("0.000000")
                                            </small>
                                        }
                                        else
                                        {
                                            <small data-location-state>Lokacija nije poslana.</small>
                                        }
                                    </article>
                                }
                            </div>
                        </section>

                        <section class="ss-live-chat" data-ss-live-chat>
                            <h3 class="h5">Chat vožnje</h3>
                            <div class="ss-live-chat-log" data-chat-log>
                                @foreach (var message in ride.Messages)
                                {
                                    <p>
                                        <strong>@message.Sender?.Ime @message.Sender?.Prezime → @(message.RecipientId == null ? "Svi" : $"{message.Recipient?.Ime} {message.Recipient?.Prezime}".Trim()):</strong>
                                        <span>@message.Message</span>
                                    </p>
                                }
                            </div>
                            <form data-chat-form>
                                <select name="recipientId" class="form-select" aria-label="Primatelj poruke">
                                    <option value="">Cijela vožnja</option>
                                    @foreach (var passenger in ride.Putnici.Where(item => item.Status == SideSeat.Models.StatusRezervacije.Potvrdena))
                                    {
                                        <option value="@passenger.PutnikId">@passenger.PutnikIme</option>
                                    }
                                </select>
                                <input name="message" class="form-control" maxlength="1000" placeholder="Poruka..." autocomplete="off" />
                                <button type="submit" class="ss-btn ss-chat-send" aria-label="Pošalji (Enter)" title="Pošalji (Enter)">⏎</button>
                            </form>
                        </section>
                    </div>

                    <div class="ss-actions">
                        @if (ride.Voznja.Status == SideSeat.Models.StatusVoznje.Planirana)
                        {
                            <form asp-action="Start" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@ride.Voznja.Id" />
                                <button type="submit" class="ss-btn" @(ride.AllReady ? null : "disabled")>Pokreni vožnju</button>
                            </form>
                        }
                        <a class="ss-btn" asp-action="Finish" asp-route-id="@ride.Voznja.Id">Završi i naplati</a>
                        <a class="ss-btn ss-btn-secondary" asp-action="Details" asp-route-id="@ride.Voznja.Id">Detalji</a>
                    </div>
                }
                else
                {
                    var res = ride.ViewerReservation;
                    var checkedIn = res?.CheckInAtUtc.HasValue == true;
                    <header class="ss-live-ride-head">
                        <div>
                            <span class="ss-badge @(checkedIn ? "is-ok" : "is-alert")" data-ready-state>
                                @(checkedIn ? "U autu" : "Čeka")
                            </span>
                            <h2>@ride.Voznja.PolazniGrad?.Naziv → @ride.Voznja.OdredisniGrad?.Naziv</h2>
                            <p>@ride.Voznja.Polazak.ToString("dd.MM.yyyy HH:mm") · @ride.Voznja.Status</p>
                            <p>Vozač: @ride.Voznja.Vozac?.Ime @ride.Voznja.Vozac?.Prezime</p>
                        </div>
                    </header>

                    <div class="ss-workflow-steps" aria-label="Koraci vožnje">
                        <span class="is-done">1. Rezervirano <span class="ss-info" tabindex="0" role="note" aria-label="Objašnjenje koraka">i<span class="ss-info-pop">Rezervirao si mjesto na ovoj vožnji.</span></span></span>
                        <span class="@(res?.Status == SideSeat.Models.StatusRezervacije.Potvrdena ? "is-done" : "is-current")">2. Potvrda vozača <span class="ss-info" tabindex="0" role="note" aria-label="Objašnjenje koraka">i<span class="ss-info-pop">Vozač mora potvrditi tvoju rezervaciju prije nego možeš napraviti check-in.</span></span></span>
                        <span class="@(checkedIn ? "is-done" : ride.ViewerCanCheckIn ? "is-current" : "")">3. U autu <span class="ss-info" tabindex="0" role="note" aria-label="Objašnjenje koraka">i<span class="ss-info-pop">Check-in i slanje lokacije dostupni su 30 min prije polaska do pokretanja vožnje.</span></span></span>
                        <span class="@(ride.Voznja.Status == SideSeat.Models.StatusVoznje.Aktivna ? "is-current" : "")">4. Vožnja aktivna <span class="ss-info" tabindex="0" role="note" aria-label="Objašnjenje koraka">i<span class="ss-info-pop">Vozač pokreće vožnju (od 30 min prije polaska do 12 h nakon termina) kad su svi spremni.</span></span></span>
                        <span>5. Završetak <span class="ss-info" tabindex="0" role="note" aria-label="Objašnjenje koraka">i<span class="ss-info-pop">Nakon vožnje slijede ocjena i plaćanje.</span></span></span>
                    </div>

                    <div class="ss-live-grid">
                        <section data-reservation-id="@res?.RezervacijaId" data-passenger-id="@res?.PutnikId">
                            <h3 class="h5">Tvoja rezervacija</h3>
                            <p>Status: @(res?.Status.ToDisplayName())</p>
                            @if (res?.LastLatitude.HasValue == true && res?.LastLongitude.HasValue == true)
                            {
                                <small data-location-state>
                                    Lokacija: @res.LastLatitude.Value.ToString("0.000000"), @res.LastLongitude.Value.ToString("0.000000")
                                </small>
                            }
                            else
                            {
                                <small data-location-state>Lokacija nije poslana.</small>
                            }

                            @if (ride.ViewerCanCheckIn)
                            {
                                <form asp-controller="Rezervacija" asp-action="CheckIn" method="post" class="ss-inline-panel" data-ss-checkin-form>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@res!.RezervacijaId" />
                                    <input type="hidden" name="latitude" data-checkin-lat />
                                    <input type="hidden" name="longitude" data-checkin-lng />
                                    <h2 class="h5">Potvrdi da si u autu</h2>
                                    <p>Prvo pronađi lokaciju na ovoj stranici, zatim je pošalji vozaču.</p>
                                    <p class="ss-checkin-status" data-checkin-status aria-live="polite">Lokacija još nije pronađena.</p>
                                    <div class="ss-checkin-actions">
                                        <button type="button" class="ss-btn ss-btn-secondary" data-checkin-locate>Pronađi lokaciju</button>
                                        <button type="submit" class="ss-btn">Pošalji lokaciju</button>
                                    </div>
                                </form>
                            }
                            else if (!checkedIn && res?.Status == SideSeat.Models.StatusRezervacije.Potvrdena)
                            {
                                <p>Check-in se otvara 30 minuta prije polaska.</p>
                            }
                            else if (res?.Status == SideSeat.Models.StatusRezervacije.UProcesuPotvrde)
                            {
                                <p>Čeka potvrdu vozača prije check-ina.</p>
                            }
                        </section>

                        <section class="ss-live-chat" data-ss-live-chat>
                            <h3 class="h5">Chat vožnje</h3>
                            <div class="ss-live-chat-log" data-chat-log>
                                @foreach (var message in ride.Messages)
                                {
                                    <p>
                                        <strong>@message.Sender?.Ime @message.Sender?.Prezime → @(message.RecipientId == null ? "Svi" : $"{message.Recipient?.Ime} {message.Recipient?.Prezime}".Trim()):</strong>
                                        <span>@message.Message</span>
                                    </p>
                                }
                            </div>
                            @if (res?.Status == SideSeat.Models.StatusRezervacije.Potvrdena)
                            {
                                <form data-chat-form>
                                    <select name="recipientId" class="form-select" aria-label="Primatelj poruke">
                                        <option value="">Cijela vožnja</option>
                                        <option value="@ride.Voznja.VozacId">Samo vozač (@ride.Voznja.Vozac?.Ime)</option>
                                    </select>
                                    <input name="message" class="form-control" maxlength="1000" placeholder="Poruka..." autocomplete="off" />
                                    <button type="submit" class="ss-btn ss-chat-send" aria-label="Pošalji (Enter)" title="Pošalji (Enter)">⏎</button>
                                </form>
                            }
                        </section>
                    </div>

                    <div class="ss-actions">
                        <a class="ss-btn ss-btn-secondary" asp-controller="Rezervacija" asp-action="Details" asp-route-id="@res?.RezervacijaId">Detalji rezervacije</a>
                    </div>
                }
                </article>
            }
        </div>
    }
</section>
