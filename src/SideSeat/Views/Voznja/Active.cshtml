@model IReadOnlyList<SideSeat.Models.Voznja>
@using SideSeat.Models.ViewModels
@{
    ViewData["Title"] = "Aktivne voznje";
    var search = ViewBag.Search as string ?? string.Empty;
    var selectedDate = ViewBag.Date as DateTime?;
    var dateFilter = new DateTimeInputViewModel
    {
        Name = "date",
        Label = "Datum",
        Value = selectedDate,
        DateOnly = true
    };
    var currentUserId = int.TryParse(User.FindFirst(SideSeat.Security.SideSeatClaimTypes.KorisnikId)?.Value, out var idValue) ? idValue : 0;
    var isAdmin = User.IsInRole("Admin");
}

<section class="ss-page" data-ss-list-page>
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <a asp-controller="Voznja" asp-action="Index">Voznje</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Aktivne voznje</span>
    </nav>

    <div class="ss-page-head">
        <h1>Aktivne voznje</h1>
        <p>Planirane voznje s dostupnim mjestima.</p>
        <div class="ss-list-toolbar">
            <div class="ss-list-search">
                <label class="form-label" for="aktivne-voznje-search">Pretraga</label>
                <input id="aktivne-voznje-search" class="form-control" type="search" value="@search" placeholder="Ruta, vozac ili ID" data-ss-list-search />
            </div>
            <div class="ss-list-pagesize">
                <label class="form-label" for="aktivne-voznje-pagesize">Prikaži</label>
                @{ var _ps = ViewBag.PageSize as int?; }
                <select id="aktivne-voznje-pagesize" class="form-select" data-ss-list-pagesize>
                    @if (_ps == 10) { <text><option value="10" selected>10</option></text> } else { <text><option value="10">10</option></text> }
                    @if (_ps == null || _ps == 25) { <text><option value="25" selected>25</option></text> } else { <text><option value="25">25</option></text> }
                    @if (_ps == 50) { <text><option value="50" selected>50</option></text> } else { <text><option value="50">50</option></text> }
                    @if (_ps == 100) { <text><option value="100" selected>100</option></text> } else { <text><option value="100">100</option></text> }
                    @if (_ps == 0) { <text><option value="0" selected>∞</option></text> } else { <text><option value="0">∞</option></text> }
                </select>
            </div>
            <div class="ss-list-date">
                <partial name="_DateTimeInput" model="dateFilter" />
            </div>
        </div>
        <div class="ss-actions">
            <a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Index">Sve voznje</a>
            <a class="ss-btn" asp-controller="Voznja" asp-action="Create">Nova voznja</a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <p class="ss-empty">Trenutno nema aktivnih voznji.</p>
    }
    else
    {
        <div class="ss-table-shell" role="region" aria-label="Lista aktivnih voznji" tabindex="0" data-ss-list-content>
            <table class="ss-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Ruta</th>
                        <th>Vozac</th>
                        <th>Polazak</th>
                        <th>Dolazak</th>
                        <th>Mjesta</th>
                        <th>Cijena / mjesto</th>
                        <th>Status</th>
                        <th>Akcija</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var voznja in Model)
                    {
                        var statusClass = voznja.Status == SideSeat.Models.StatusVoznje.Planirana
                            ? "is-ok"
                            : voznja.Status == SideSeat.Models.StatusVoznje.Zavrsena
                                ? "is-alert"
                                : "is-off";

                        <tr>
                            <td>@voznja.Id</td>
                            <td>@voznja.PolazniGrad?.Naziv -> @voznja.OdredisniGrad?.Naziv</td>
                            <td>@voznja.Vozac?.Ime @voznja.Vozac?.Prezime</td>
                            <td>@voznja.Polazak.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@voznja.OcekivaniDolazak.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@voznja.SlobodnaMjesta / @voznja.UkupnoMjesta</td>
                            <td>@voznja.CijenaPoMjestu.ToString("0.00") EUR</td>
                            <td><span class="ss-badge @statusClass">@voznja.Status</span></td>
                            <td>
                                <a class="ss-btn" asp-controller="Voznja" asp-action="Details" asp-route-id="@voznja.Id">Detalji</a>
                                @if (isAdmin || voznja.VozacId == currentUserId)
                                {
                                    <a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Edit" asp-route-id="@voznja.Id">Uredi</a>
                                    <a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Delete" asp-route-id="@voznja.Id">Obrisi</a>
                                }
                                else if (voznja.SlobodnaMjesta > 0)
                                {
                                    <a class="ss-btn ss-btn-secondary" asp-controller="Rezervacija" asp-action="Create" asp-route-voznjaId="@voznja.Id">Rezerviraj</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
