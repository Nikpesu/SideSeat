@model IReadOnlyList<SideSeat.Models.Voznja>
@{
    ViewData["Title"] = "Aktivne voznje";
    var currentUserId = int.TryParse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var idValue) ? idValue : 0;
    var isAdmin = User.IsInRole("Admin");
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <a asp-controller="Voznja" asp-action="Index">Voznje</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Aktivne voznje</span>
    </nav>

    <div class="ss-page-head">
        <h1>Aktivne voznje</h1>
        <p>Planirane voznje s dostupnim mjestima.</p>
        <div class="ss-actions">
            <a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Index">Sve voznje</a>
            <a class="ss-btn" asp-controller="Voznja" asp-action="Create">Nova voznja</a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <p class="ss-empty">Trenutno nema aktivnih voznji.</p>
    }
    else
    {
        <div class="ss-table-shell" role="region" aria-label="Lista aktivnih voznji" tabindex="0">
            <table class="ss-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Ruta</th>
                        <th>Vozac</th>
                        <th>Polazak</th>
                        <th>Dolazak</th>
                        <th>Mjesta</th>
                        <th>Cijena / mjesto</th>
                        <th>Status</th>
                        <th>Akcija</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var voznja in Model)
                    {
                        var statusClass = voznja.Status == SideSeat.Models.StatusVoznje.Planirana
                            ? "is-ok"
                            : voznja.Status == SideSeat.Models.StatusVoznje.Zavrsena
                                ? "is-alert"
                                : "is-off";

                        <tr>
                            <td>@voznja.Id</td>
                            <td>@voznja.PolazniGrad?.Naziv -> @voznja.OdredisniGrad?.Naziv</td>
                            <td>@voznja.Vozac?.Ime @voznja.Vozac?.Prezime</td>
                            <td>@voznja.Polazak.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@voznja.OcekivaniDolazak.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@voznja.SlobodnaMjesta / @voznja.UkupnoMjesta</td>
                            <td>@voznja.CijenaPoMjestu.ToString("0.00") EUR</td>
                            <td><span class="ss-badge @statusClass">@voznja.Status</span></td>
                            <td>
                                <a class="ss-btn" asp-controller="Voznja" asp-action="Details" asp-route-id="@voznja.Id">Detalji</a>
                                @if (isAdmin || voznja.VozacId == currentUserId)
                                {
                                    <a class="ss-btn ss-btn-secondary" asp-controller="Voznja" asp-action="Edit" asp-route-id="@voznja.Id">Uredi</a>
                                }
                                else if (voznja.SlobodnaMjesta > 0)
                                {
                                    <a class="ss-btn ss-btn-secondary" asp-controller="Rezervacija" asp-action="Create" asp-route-voznjaId="@voznja.Id">Rezerviraj</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
