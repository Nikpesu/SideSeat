@model SideSeat.Models.Ocjena.CreateOcjenaViewModel
@{
    ViewData["Title"] = Model.IsAdditional ? "Dodatna recenzija" : "Ocijeni voznju";
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Pocetna</a>
        <span class="ss-breadcrumb-sep">/</span>
        <a asp-controller="Rezervacija" asp-action="Index">Rezervacije</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Ocjenjivanje</span>
    </nav>

    <div class="ss-page-head">
        <h1>@(Model.IsAdditional ? "Dodaj dodatnu recenziju" : "Ocijeni vožnju")</h1>
        <p>Ostavi @(Model.IsAdditional ? "dodatnu recenziju" : "ocjenu i komentar") za @Model.TargetName.</p>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="ss-detail-card">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="RezervacijaId" />
        <input type="hidden" asp-for="IsAdditional" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="BrojZvjezdica" class="form-label">Broj zvjezdica</label>
            <select asp-for="BrojZvjezdica" class="form-select">
                <option value="5">5</option>
                <option value="4">4</option>
                <option value="3">3</option>
                <option value="2">2</option>
                <option value="1">1</option>
            </select>
            <span asp-validation-for="BrojZvjezdica" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Komentar" class="form-label"></label>
            <textarea asp-for="Komentar" class="form-control" rows="4" placeholder="Napiši komentar..."></textarea>
            <span asp-validation-for="Komentar" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Slike" class="form-label">Slike recenzije</label>
            <div class="ss-file-picker">
                <input asp-for="Slike" type="file" class="ss-file-picker-input" accept="image/*" multiple data-ss-file-picker />
                <label for="Slike" class="ss-file-picker-button">Odaberi slike</label>
                <span class="ss-file-picker-status" data-ss-file-picker-status>Nijedna slika nije odabrana.</span>
            </div>
            <span asp-validation-for="Slike" class="text-danger"></span>
            <small class="ss-datetime-help d-block mt-2">Mozes dodati do 5 slika, najvise 5 MB po slici.</small>
        </div>

        @if (Model.CanTipDriver)
        {
            <section class="ss-inline-panel">
                <h2 class="h5">Napojnica vozaču karticom</h2>
                <p class="ss-muted">Napojnica se dodaje samo ovdje, nakon završene vožnje i pri prvoj ocjeni vozača. Ne skida se sa SideSeat salda putnika.</p>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Napojnica" class="form-label"></label>
                        <input asp-for="Napojnica" class="form-control" min="0" max="10000" step="0.01" />
                        <span asp-validation-for="Napojnica" class="text-danger"></span>
                    </div>
                    <div class="col-md-8">
                        <label asp-for="CardholderName" class="form-label"></label>
                        <input asp-for="CardholderName" class="form-control" autocomplete="cc-name" />
                        <span asp-validation-for="CardholderName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CardNumber" class="form-label"></label>
                        <input asp-for="CardNumber" class="form-control" inputmode="numeric" autocomplete="cc-number" placeholder="1234 5678 9012 3456" />
                        <span asp-validation-for="CardNumber" class="text-danger"></span>
                        @if (!string.IsNullOrWhiteSpace(Model.SavedCardDisplay))
                        {
                            <small class="ss-datetime-help">Ako ostaviš prazno, koristi se spremljena kartica @Model.SavedCardDisplay.</small>
                        }
                    </div>
                    <div class="col-md-3">
                        <label asp-for="CardExpiry" class="form-label"></label>
                        <input asp-for="CardExpiry" class="form-control" inputmode="numeric" autocomplete="cc-exp" placeholder="MM/YY" />
                        <span asp-validation-for="CardExpiry" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="CardCvv" class="form-label"></label>
                        <input asp-for="CardCvv" class="form-control" inputmode="numeric" autocomplete="cc-csc" placeholder="123" />
                        <span asp-validation-for="CardCvv" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label class="ss-check-row">
                            <input asp-for="SaveCard" />
                            <span>Spremi ovu mock karticu za buduće uplate i napojnice.</span>
                        </label>
                    </div>
                </div>
            </section>
        }
        else if (Model.ExistingTip > 0)
        {
            <section class="ss-inline-panel">
                <h2 class="h5">Napojnica je već evidentirana</h2>
                <p class="ss-muted">Za ovu rezervaciju je već dodana napojnica @Model.ExistingTip.ToString("0.00") EUR.</p>
            </section>
        }

        <div class="ss-actions">
            <button class="ss-btn" type="submit">Spremi ocjenu</button>
            <a class="ss-btn ss-btn-secondary" asp-controller="Rezervacija" asp-action="Index">Natrag</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
