@model SideSeat.Models.ViewModels.OcjenaAdminFormViewModel
@{
    ViewData["Title"] = "Uredi ocjenu";
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <a asp-controller="Ocjena" asp-action="Index">Ocjene</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Uredi ocjenu</span>
    </nav>

    <div class="ss-page-head">
        <h1>Uredi ocjenu</h1>
        <p>Azurirajte zvjezdice, komentar i datum unosa.</p>
    </div>

    <form asp-action="AdminEdit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <partial name="_AdminForm" model="Model" />

        <div class="ss-actions">
            <button type="submit" class="ss-btn">Spremi promjene</button>
            <a class="ss-btn ss-btn-secondary" asp-action="Details" asp-route-id="@Model.Id">Odustani</a>
        </div>
    </form>
</section>
