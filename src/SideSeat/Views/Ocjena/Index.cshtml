@model IReadOnlyList<SideSeat.Models.OcjenaVoznje>
@{
	ViewData["Title"] = "Ocjene";
}

<section class="ss-page">
	<nav class="ss-breadcrumb" aria-label="Breadcrumb">
		<a asp-controller="Home" asp-action="Index">Dashboard</a>
		<span class="ss-breadcrumb-sep">/</span>
		<span class="current" aria-current="page">Ocjene</span>
	</nav>

	<div class="ss-page-head">
		<h1>Ocjene voznji</h1>
		<p>Pregled ocjena koje su korisnici ostavili nakon voznje.</p>
	</div>

	@if (Model.Count == 0)
	{
		<p class="ss-empty">Nema unesenih ocjena.</p>
	}
	else
	{
		<div class="ss-table-shell" role="region" aria-label="Lista ocjena" tabindex="0">
			<table class="ss-table">
				<thead>
					<tr>
						<th>ID</th>
						<th>Autor</th>
						<th>Rezervacija</th>
						<th>Zvjezdice</th>
						<th>Komentar</th>
						<th>Kreirano</th>
						<th>Akcija</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var ocjena in Model)
					{
						<tr>
							<td>@ocjena.Id</td>
							<td>@ocjena.Autor?.Ime @ocjena.Autor?.Prezime</td>
							<td>#@ocjena.RezervacijaId</td>
							<td>@(new string('*', ocjena.BrojZvjezdica)) (@ocjena.BrojZvjezdica/5)</td>
							<td>@ocjena.Komentar</td>
							<td>@ocjena.Kreirano.ToString("dd.MM.yyyy HH:mm")</td>
							<td>
								<a class="ss-btn" asp-controller="Ocjena" asp-action="Details" asp-route-id="@ocjena.Id">Detalji</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
</section>
