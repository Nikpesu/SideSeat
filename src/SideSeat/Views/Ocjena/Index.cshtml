@model SideSeat.Models.Ocjena.OcjenaTabViewModel
@{
    ViewData["Title"] = "Ocjene";
    var isAdmin = User.IsInRole("Admin");
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Ocjene</span>
    </nav>

    <div class="ss-page-head">
        <h1>Moje ocjene</h1>
        <p>Ocijeni odvozene voznje i prati dane/primljene ocjene.</p>
        @if (isAdmin)
        {
            <div class="ss-actions mt-3">
                <a class="ss-btn" asp-action="AdminCreate">Dodaj administratorsku recenziju</a>
                <a class="ss-btn ss-btn-secondary" asp-action="Attachments">Privitci recenzija</a>
            </div>
        }
    </div>

    <div class="ss-detail-card mb-4">
        <h2 class="h5">Prosjeci</h2>
        <dl class="ss-detail-grid">
            <div>
                <dt>Dane ocjene (prosjek)</dt>
                <dd>@(Model.Given.Count == 0 ? "Nema ocjena" : Model.GivenAverage.ToString("0.0"))</dd>
            </div>
            <div>
                <dt>Primljene ocjene (prosjek)</dt>
                <dd>@(Model.Received.Count == 0 ? "Nema ocjena" : Model.ReceivedAverage.ToString("0.0"))</dd>
            </div>
        </dl>
    </div>

    <div class="ss-detail-card mb-4">
        <h2 class="h5">Odvozene voznje bez moje ocjene</h2>
        @if (Model.Pending.Count == 0)
        {
            <p class="ss-empty">Nema voznji koje jos mozes ocijeniti.</p>
        }
        else
        {
            <div class="ss-table-shell" role="region" aria-label="Voznje za ocjenjivanje" tabindex="0">
                <table class="ss-table">
                    <thead>
                        <tr>
                            <th>Rezervacija</th>
                            <th>Ruta</th>
                            <th>Datum voznje</th>
                            <th>Ocijeniti</th>
                            <th>Akcija</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.Pending)
                    {
                        <tr>
                            <td>#@row.RezervacijaId</td>
                            <td>@row.RouteLabel</td>
                            <td>@row.RideDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@row.TargetName</td>
                            <td>
                                <a class="ss-btn" asp-controller="Ocjena" asp-action="Create" asp-route-rezervacijaId="@row.RezervacijaId">Dodaj ocjenu</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="ss-detail-card mb-4">
        <h2 class="h5">Ocjene koje sam dao</h2>
        @if (Model.Given.Count == 0)
        {
            <p class="ss-empty">Jos nisi dao nijednu ocjenu.</p>
        }
        else
        {
            <div class="ss-table-shell" role="region" aria-label="Dane ocjene" tabindex="0">
                <table class="ss-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Rezervacija</th>
                            <th>Ruta</th>
                            <th>Primatelj</th>
                            <th>Zvjezdice</th>
                            <th>Komentar</th>
                            <th>Datum</th>
                            <th>Akcije</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.Given)
                    {
                        <tr>
                            <td>@row.OcjenaId</td>
                            <td>#@row.RezervacijaId</td>
                            <td>@row.RouteLabel</td>
                            <td>@row.TargetName</td>
                            <td>@row.BrojZvjezdica/5</td>
                            <td>
                                @row.Komentar
                                @if (row.Administratorska)
                                {
                                    <small class="d-block ss-datetime-help">Administratorska recenzija</small>
                                }
                                @if (row.Uredeno.HasValue)
                                {
                                    <small class="d-block ss-datetime-help">Uređena recenzija @row.Uredeno.Value.ToString("dd.MM.yyyy HH:mm")</small>
                                }
                                <partial name="_OcjenaSlike" model="row.Slike" />
                            </td>
                            <td>@row.Kreirano.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <div class="ss-actions">
                                    <a class="ss-btn ss-btn-secondary" asp-action="Edit" asp-route-id="@row.OcjenaId">Uredi</a>
                                    <a class="ss-btn" asp-action="Create" asp-route-rezervacijaId="@row.RezervacijaId">Dodatna recenzija</a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="ss-detail-card">
        <h2 class="h5">Ocjene koje sam dobio</h2>
        @if (Model.Received.Count == 0)
        {
            <p class="ss-empty">Jos nemas primljenih ocjena.</p>
        }
        else
        {
            <div class="ss-table-shell" role="region" aria-label="Primljene ocjene" tabindex="0">
                <table class="ss-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Rezervacija</th>
                            <th>Ruta</th>
                            <th>Autor</th>
                            <th>Zvjezdice</th>
                            <th>Komentar</th>
                            <th>Datum</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.Received)
                    {
                        <tr>
                            <td>@row.OcjenaId</td>
                            <td>#@row.RezervacijaId</td>
                            <td>@row.RouteLabel</td>
                            <td>@row.AuthorName</td>
                            <td>@row.BrojZvjezdica/5</td>
                            <td>
                                @row.Komentar
                                @if (row.Administratorska)
                                {
                                    <small class="d-block ss-datetime-help">Administratorska recenzija</small>
                                }
                                @if (row.Uredeno.HasValue)
                                {
                                    <small class="d-block ss-datetime-help">Uređena recenzija @row.Uredeno.Value.ToString("dd.MM.yyyy HH:mm")</small>
                                }
                                <partial name="_OcjenaSlike" model="row.Slike" />
                            </td>
                            <td>@row.Kreirano.ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @if (isAdmin)
    {
        <div class="ss-detail-card mt-4">
            <h2 class="h5">Sve recenzije (admin)</h2>
            @if (Model.AdminAll.Count == 0)
            {
                <p class="ss-empty">Nema recenzija.</p>
            }
            else
            {
                <div class="ss-table-shell" role="region" aria-label="Sve recenzije" tabindex="0">
                    <table class="ss-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Rezervacija</th>
                                <th>Autor</th>
                                <th>Primatelj</th>
                                <th>Ocjena</th>
                                <th>Komentar</th>
                                <th>Akcije</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.AdminAll)
                        {
                            <tr>
                                <td>#@row.OcjenaId</td>
                                <td>#@row.RezervacijaId</td>
                                <td>@row.AuthorName</td>
                                <td>@row.TargetName</td>
                                <td>@row.BrojZvjezdica/5</td>
                                <td>
                                    @row.Komentar
                                    @if (row.Administratorska)
                                    {
                                        <small class="d-block ss-datetime-help">Administratorska recenzija</small>
                                    }
                                    @if (row.Uredeno.HasValue)
                                    {
                                        <small class="d-block ss-datetime-help">Uređena recenzija</small>
                                    }
                                    <partial name="_OcjenaSlike" model="row.Slike" />
                                </td>
                                <td>
                                    <div class="ss-actions">
                                        <a class="ss-btn" asp-action="Details" asp-route-id="@row.OcjenaId">Detalji</a>
                                        <a class="ss-btn ss-btn-secondary" asp-action="AdminEdit" asp-route-id="@row.OcjenaId">Uredi</a>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</section>
