@model SideSeat.Models.Ocjena.EditOcjenaViewModel
@{
    ViewData["Title"] = "Uredi recenziju";
}

<section class="ss-page">
    <nav class="ss-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="ss-breadcrumb-sep">/</span>
        <a asp-controller="Ocjena" asp-action="Index">Ocjene</a>
        <span class="ss-breadcrumb-sep">/</span>
        <span class="current" aria-current="page">Uredi recenziju</span>
    </nav>

    <div class="ss-page-head">
        <h1>Uredi recenziju</h1>
        <p>Promijeni ocjenu, komentar ili dodaj slike za @Model.TargetName.</p>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="ss-detail-card">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RezervacijaId" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="BrojZvjezdica" class="form-label">Broj zvjezdica</label>
            <select asp-for="BrojZvjezdica" class="form-select">
                <option value="5">5</option>
                <option value="4">4</option>
                <option value="3">3</option>
                <option value="2">2</option>
                <option value="1">1</option>
            </select>
            <span asp-validation-for="BrojZvjezdica" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Komentar" class="form-label"></label>
            <textarea asp-for="Komentar" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Komentar" class="text-danger"></span>
        </div>

        @if (Model.PostojeceSlike.Count > 0)
        {
            <div class="mb-3">
                <strong>Postojeće slike</strong>
                <partial name="_OcjenaSlike" model="Model.PostojeceSlike" />
                <small class="ss-datetime-help">Klikni sliku za uvećanje i mogućnost brisanja.</small>
            </div>
        }

        <div class="mb-3">
            <label asp-for="Slike" class="form-label">Dodaj slike</label>
            <div class="ss-file-picker">
                <input asp-for="Slike" type="file" class="ss-file-picker-input" accept="image/*" multiple data-ss-file-picker />
                <label for="Slike" class="ss-file-picker-button">Odaberi slike</label>
                <span class="ss-file-picker-status" data-ss-file-picker-status>Nijedna slika nije odabrana.</span>
            </div>
            <span asp-validation-for="Slike" class="text-danger"></span>
            <small class="ss-datetime-help d-block mt-2">Recenzija može imati ukupno najviše 5 slika.</small>
        </div>

        <div class="ss-actions">
            <button class="ss-btn" type="submit">Spremi promjene</button>
            <a class="ss-btn ss-btn-secondary" asp-action="Index">Odustani</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
